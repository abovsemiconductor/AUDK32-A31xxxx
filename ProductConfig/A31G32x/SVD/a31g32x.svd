    <!--Temp Sensor-->
    <peripheral>
      <name>TEMP</name>
      <version>1.0</version>
      <description>Temp Sensor</description>
      <groupName>TEMP</groupName>
      <baseAddress>0x40006300</baseAddress>
      <size>32</size>
      <access>read-write</access>
      <addressBlock>
        <offset>0</offset>
        <size>0x010</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>TEMPERATURE</name>
        <value>28</value>
      </interrupt>
      <registers>
      <!-- TSENSECON: Temp Sensor Control Register -->
        <register>
          <name>TSENSECON</name>
          <description>Temp Sensor Control Register</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <resetMask>0x0000000f</resetMask>
          <fields>
            <field>
              <name>TSSINTEN</name>
              <description>Temp Sensor interrupt enable</description>
              <bitRange>[03:03]</bitRange>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE_TEMPINT</name>
                  <description>Temp sensor interrupt disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE_TEMPINT</name>
                  <description>Temp sensor interrupt enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>TSSFLAG</name>
              <description>Temp Sensor CNT match flag</description>
              <bitRange>[02:02]</bitRange>
              <access>read-write</access>
            </field>
            <field>
              <name>TSSTART</name>
              <description>Temp Sensor start</description>
              <bitRange>[01:01]</bitRange>
              <access>read-write</access>
            </field>
            <field>
              <name>TSSEN</name>
              <description>Temp Sensor enable</description>
              <bitRange>[00:00]</bitRange>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <!-- TSREFPEROID: Temp Sensor Reference Clock Period Register -->
        <register>
          <name>TSREFPEROID</name>
          <description>Temp Sensor Reference Clock Period Register</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x000fffff</resetValue>
          <resetMask>0x000fffff</resetMask>
          <fields>
            <field>
              <name>TSREFPERIOD</name>
              <description>Temp Sensor Reference Clock Period Register</description>
              <bitRange>[19:00]</bitRange>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <!-- TSSENSECNT: Temp Sensor Sense Clock Count Register -->
        <register>
          <name>TSSENSECNT</name>
          <description>Temp Sensor Sense Clock Count Register</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <resetMask>0x000000ff</resetMask>
          <fields>
            <field>
              <name>TSSENSECNT</name>
              <description>Temp Sensor Reference Count Register</description>
              <bitRange>[15:00]</bitRange>
              <access>read-only</access>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
  </peripherals>
</device>
