              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>NCSKIP</name>
              <description>Noise Cancel Bypass enable for External SOSC</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <!--EMODR : External mode pin read register-->
        <register>
          <name>EMODR</name>
