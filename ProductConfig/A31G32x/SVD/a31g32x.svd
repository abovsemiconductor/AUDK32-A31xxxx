        <resetMask>0xffffffff</resetMask>
        <fields>
          <field>
            <name>BKUPDR</name>
            <description>Backup Register</description>
            <bitOffset>0</bitOffset>
            <bitWidth>32</bitWidth>
          </field>
        </fields>
      </register>
      <!-- BKUPDR3: Backup Register 3 -->
      <register>
        <name>BKUPDR3</name>
        <description>Backup Register 3</description>
        <addressOffset>0x40</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <resetMask>0xffffffff</resetMask>
          <fields>
            <field>
              <name>BKUPDR</name>
              <description>Backup Register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
          </fields>
        </register>
        <!-- BKUPDR: Backup Register 4 -->
        <register>
          <name>BKUPDR4</name>
          <description>Backup Register 4</description>
          <addressOffset>0x44</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <resetMask>0xffffffff</resetMask>
          <fields>
            <field>
              <name>BKUPDR</name>
              <description>Backup Register</description>
              <bitOffset>0</bitOffset>
