          <fields>
            <field>
              <name>BKUPDR</name>
              <description>Backup Register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>32</bitWidth>
            </field>
        </fields>
      </register>
      <!-- BKUPDR2: Backup Register 2 -->
      <register>
        <name>BKUPDR2</name>
