      <access>read-write</access>
      <addressBlock>
        <offset>0</offset>
        <size>0x020</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>TIMER20</name>
        <value>15</value>
      </interrupt>
      <registers>
        <register>
          <name>CR</name>
          <description>Timer/Counter n Control Register</description>
          <addressOffset>0x00</addressOffset>
          <size>32</size>
