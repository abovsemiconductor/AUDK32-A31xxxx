            </field>
          </fields>
        </register>
        <!-- RTCPFCR: RTC Pin Function Configuration Register -->
        <register>
          <name>RTCPFCR</name>
          <description>RTC Pin Function Configuration Register</description>
          <addressOffset>0x48</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <resetMask>0x000007ff</resetMask>
          <fields>
            <field>
              <name>PC13WK_EDGE</name>
              <description>PC13 wakeup event occurrence mode (level or edge)</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PC13WKPOL</name>
              <description>PC13 wakeup event occurrence mode (polarity)</description>
              <bitOffset>9</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>PC15MODE</name>
              <description>PC15 mode</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PC15VALUE</name>
              <description>PC15 value
If the LSE is disabled and PC15MODE=1, PC15VALUE configures the PC15 output data</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PC14MODE</name>
              <description>PC14 mode</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PC14VALUE</name>
              <description>PC14 value
If the LSE is disabled and PC14MODE=1, PC14VALUE configures the PC14 output data</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PC13MODE</name>
              <description>PC13 mode</description>
              <bitOffset>2</bitOffset>
              <bitWidth>2</bitWidth>
            </field>
            <field>
              <name>PC13VALUE</name>
              <description>PC13 value
If PC13MODE=01, PC13VALUE configures the PC13 output data</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PC13WKUEN</name>
              <description>Wakeup pin enable</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
          </fields>
        </register>
