    <peripheral>
      <name>I2C0</name>
      <groupName>I2C</groupName>
      <headerStructName>I2C</headerStructName>
      <description>Inter-Integrated Circuit</description>
      <baseAddress>0x4000A000</baseAddress>
      <addressBlock>
        <offset>0x00000000</offset>
        <size>0x0100</size>
        <usage>registers</usage>
      </addressBlock>
      <interrupt>
        <name>I2C0</name>
        <value>19</value>
      </interrupt>
      <registers>
        <register>
          <name>DR</name>
          <description>I2C data register</description>
          <addressOffset>0x0000</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x000000FF</resetValue>
          <fields>
            <field>
              <name>ICDR</name>
              <description>In transmit mode, the data stored in this register is outputted from pin SDA in the serial data line. In receive mode, data received at pin SDA is stored in this register; hence, the stored data is loaded by reading this register</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SR</name>
          <description>I2C status register</description>
          <addressOffset>0x0008</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>GCALL</name>
              <description>This bit signifies different things, depending on whether the I2C is in master or slave mode.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>TEND</name>
              <description>One-byte transmit end flag</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>STOP</name>
              <description>Stop flag</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SSEL</name>
              <description>Slave flag</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>MLOST</name>
              <description>Mastership loss flag</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>BUSY</name>
              <description>Bus busy flag</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TMOD</name>
              <description>Transmit / receive mode flag</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>RXACK</name>
              <description>Rx ACK flag</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>SAR</name>
          <description>I2C slave address register</description>
          <addressOffset>0x000C</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SVAD</name>
              <description>7-bit slave address</description>
              <bitOffset>1</bitOffset>
              <bitWidth>7</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>GCEN</name>
              <description>Whether to enable or disable general call</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CR</name>
          <description>I2C Control Register</description>
          <addressOffset>0x0014</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>INTDEL</name>
              <description>Internal delay between address and data transfers (Or between two data transfers)</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>1_ICnSCLL</name>
                  <description>Delay = 1*ICnSCLL</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>2_ICnSCLL</name>
                  <description>Delay = 2*ICnSCLL</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>4_ICnSCLL</name>
                  <description>Delay = 4*ICnSCLL</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>8_ICnSCLL</name>
                  <description>Delay = 8*ICnSCLL</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>IIF</name>
