              <access>read-write</access>
            </field>
            <field>
              <name>SW_SYNC</name>
              <description>Generate Software SYNC event 0: No Action 1: A software SYNC event is generate</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>AUTOTRIM_EN</name>
              <description>Auto Trim Enable 0: Auto trimming disable 1: Auto trimming enable *This bit enables the automatic hardware adjustment of TRIM bits according to the measured frequency error between two SYNC events. If this bit is set, the TRIM bits are read-only. The TRIM value can be adjusted by hardware by one or two ot three steps at a time, depending on the measured frequency error value. ** Before setting this bit, you must load the trim value into the trim register and set SET_TRIMVALUE BIT to 1.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>HSICMU_EN</name>
              <description>HSICMU Peripheral block Enable 0: disable 1: enable</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>CFG</name>
          <description>High Speed Internal OSC Clock Management Unit Config Register</description>
          <addressOffset>0x0004</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x0000FFFF</resetValue>
          <fields>
            <field>
              <name>SESYNCPOL</name>
              <description>This bit is set and cleared by software to select the input polarity for the SYNC signal source. 00: Both edge. 01: Rising edge. 10: Falling edge. 11: RESERVED.</description>
              <bitOffset>30</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>Both_edge</name>
                  <description>Both_edge</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Rising_edge</name>
                  <description>Rising_edge</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>Falling_edge</name>
                  <description>Falling_edge</description>
                  <value>2</value>
                </enumeratedValue>
              </enumeratedValues>
            </field>
            <field>
              <name>SYNCSRC</name>
              <description>SYNC Signal Source Selection These bits are set and cleared by software to select the SYNC signal source. 00: Capture Data Update when SOF is successfully received. 01: Capture Data Update when SOF is successfully received and also even when SOF is missed. 10: SOSC CLK. 11: GPIO.</description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>AC_EN</name>
              <description>Auto Clear Enable 0: No Action 1: Auto Clear Enable</description>
              <bitOffset>27</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>SYNCDIV</name>
              <description>SYNC Divider These bits are set and cleared by software to control the division factor of the SYNC signal. 000: SYNC not divided (default) 001: SYNC divided by 2 010: SYNC divided by 4 011: SYNC divided by 8 100: SYNC divided by 16 101: SYNC divided by 32 110: SYNC divided by 64 111: SYNC divided by 128</description>
              <bitOffset>24</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>PREDIV</name>
              <description>Pre divider</description>
              <bitOffset>20</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>RELOAD</name>
              <description>Sync Timer Reload Value RELOAD is the value to be loaded in the Synctimer with each SYNC event.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>20</bitWidth>
              <access>read-write</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ISR</name>
          <description>High Speed Internal OSC Clock Management Unit Interrupt &amp; Status Register</description>
          <addressOffset>0x0008</addressOffset>
          <size>0x20</size>
          <access>read-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>FECDIR</name>
              <description>Frequency Error Capture Direction 0: count under reload 1: count over reload</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNC_FLAG</name>
              <description>Sync Signal Flag 0: None 1: Updated HSICMU_CAP register with input sync signal</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>TRIMOVF</name>
              <description>Trim Value Over flow 0: None 1: The trim value is out of limits when AUTOTRIMEN = 1</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>FECOVF</name>
              <description>Frequency Error Capture Over Flow 0: None 1: The Counter value changed in the increasing direction and the counter value increased to the end (0xFFFF)</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_4</name>
              <description>FETHR * 128 &lt; HSICMU_CAP</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_3</name>
              <description>FETHR * 4 &lt; HSICMU_CAP &lt;= FETHR * 128</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_2</name>
              <description>FETHR * 2 &lt; HSICMU_CAP &lt;= FETHR *4</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_1</name>
              <description>FETHR &lt; HSICMU_CAP &lt;= FETHR * 2</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
            <field>
              <name>SYNCLVL_0</name>
              <description>HSICMU_CAP &lt;= FETHR</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>ICR</name>
          <description>High Speed Internal OSC Clock Management Unit Interrupt &amp; Status Clear Register</description>
          <addressOffset>0x000C</addressOffset>
          <size>0x20</size>
          <access>write-only</access>
          <resetValue>0x00000000</resetValue>
          <fields>
            <field>
              <name>SYNC_FLAG</name>
