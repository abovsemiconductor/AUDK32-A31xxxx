; A. Description
;    A list of commands here configures PCU module and controls a output level of a target port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PA6 (Output)
;               : PA7 (Input)
;
; E. Port Connection
;    1. PA6 (Output) ----> PA7 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PA6)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 6 o p h ]
;    Pin Number                : 6
;    Pin Mode                  : o (Output)
;    Pin Output Mode           : p (Push-Pull)
;    Pin Level                 : h (High)
;
; 3. Output                    : [ 0 8 l / h ]
;    Pin Number                : 8
;    Pin Level                 : l (Low) / h (High)
;
; PCU (PA7)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 7 i i ]
;    Pin Number                : 7
;    Pin Mode                  : i (input)
;    Pin Output Mode           : i (input)
;
; 3. Input                     : [ 0 7 ]
;    Pin Number                : 7
;
; PCU (PA6)
sendln 'cm pcu'
mpause 30
sendln 'port 0 6 o p h'
mpause 30

; PCU (PA7)
sendln 'port 0 7 i i'
mpause 30

i = 30
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 0 6 l'
    else
        sendln 'output 0 6 h'
    endif
    mpause 30 
    sendln 'input 0 7'
    pause 1
loop
