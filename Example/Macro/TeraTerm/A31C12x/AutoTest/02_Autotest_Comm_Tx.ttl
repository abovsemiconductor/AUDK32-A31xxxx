; A. Description
;    This script automatically executes UART and USART TX Tera Term example scripts.
;    The 02_Autotest_Comm_Rx.ttl must be executed before running this script.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. I2C
;    3. USART
;
; C. Port Connection (Testing must be conducted with two Starterkits)
;    1. I2C
;     : PD0 (Serial Clock) <--> PD0 (Serial Clock)
;     : PD1 (Serial Data)  <--> PD1 (Serial Data)
;    2. USART1
;     : PD2 (USART1 Transmit) <--> PD3 (USART1 Receive)
;     : PD3 (USART1 Receive) <--> PD2 (USART1 Transmit)
;

getdir mdir
fileret='02_Autotest_Result_Comm_Tx'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
pause 1
fileopen frethnd retfilename 0

call tcusart
call tci2c

fileclose frethnd
dispstr 'End of 2.Auto Test Comm Tx'
end


:tcusart
;===== START : TestCase USART TX between STKs =====
dispstr 10 10
dispstr '===== START : TestCase USART TX between STKs ====='
dispstr 10

ipstr='USART'
filestr='02_usart_uart_intr_tx'
delay=5
call dotest

;===== END : TestCase USART TX between STKs =====
dispstr 10
dispstr '===== END : TestCase USART TX between STKs ====='
dispstr 10
return


:tci2c
;===== START : TestCase I2C TX between STKs =====
dispstr 10 10
dispstr '===== START : TestCase I2C TX between STKs ====='
dispstr 10

ipstr='I2C'
filestr='02_i2c_master_intr_tx_sa_0x49'
delay=5
call dotest

ipstr='I2C'
filestr='04_i2c_slave_intr_tx_sa_0x49'
delay=10
call dotest

;===== END : TestCase I2C TX between STKs =====
dispstr 10
dispstr '===== END : TestCase I2C TX between STKs ====='
dispstr 10
return

:dotest
sprintf2 filename '%s\%s\%s.log' mdir ipstr filestr
sprintf2 delfilename '%s\%s.log' ipstr filestr
filedelete delfilename
sprintf2 logstr 'Test %s' filestr
sprintf2 testfile '..\%s\%s.ttl' ipstr filestr
logopen filename 0 0
logwrite logstr
include testfile
pause delay
logclose
call decision
return

:decision
timeout=600
fileopen fhandle filename 0
fileseek fhandle 0 0
do
    filereadln fhandle line
    filewriteln frethnd line
loop while result == 0
filewriteln frethnd 0
filewriteln frethnd 0
fileclose fhandle
pause 1
return
