; A. Description
;    A list of commands here configures ADC and generates single capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PE2 (AN16)
;    2. Timer15 : PC0 (Output/Capture Input/External Clock Input)
;
; E. Port Connection
;    1. PC0 (Timer15 Output) ----> PE2 (AN16)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 63 ]
;    Source                     : p (Peripheral Clock)
;    Peripheral Clock Divide    : 63 (Divide + 1)
;
; 3. Config                     : [ config 0 i s a 1 0 ]
;    Operation                  : i (Interrupt)
;    Mode                       : s (Single)
;    Base Trigger Source        : a (ADC Instant Start)
;    Sequence Count             : 1
;    Sampling Time              : 0
;
; 4. Seq                        : [ 0 a 0 16 ]
;    Trigger Source             : a (ADC Instant Start)
;    Sequence Number            : 0
;    Input Channel              : 16
;
; Timer15
; 1. Channel                    : 5 (Timer15)
;
; 2. Clock                      : [ 5 m h 4 64 -io o ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 4 
;    Timer1 Pre-Divide          : 64 (MCCR Clock / 4) / 64
;
; 3. Config                     : [ 5 i p h 13 13 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 13
;    B Data                     : 13
;    Port In/Out (-io)          : o (Output)
;
; PCU (PE2)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 2 a 7 ]
;    Pin Number                : 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 7 (AN16)
; 
; PCU (PC0)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 0 a 2 ]
;    Pin Number                : 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (T5IO)
; 
; PCU (PE)
sendln 'cm pcu'
mpause 30
sendln 'port 4 2 a 7'
mpause 30

; PCU (PC)
sendln 'port 2 0 a 2'
mpause 30

; Timer15
sendln 'cm timer1'
mpause 30
sendln 'uninit 5'
mpause 30
sendln 'init 5'
mpause 30
sendln 'clk 5 m h 4 64'
mpause 30
sendln 'config 5 i p h 13 13' 
mpause 30
sendln 'log off'
mpause 30
sendln 'start 5'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 63'
mpause 30
sendln 'config 0 i s a 1 0'
mpause 30
sendln 'seq 0 a 0 16'
mpause 30
sendln 'start 0'
pause 2
sendln 'dump 0'
pause 2
sendln 'stop 0'
mpause 30

; Timer15
sendln 'cm timer1'
mpause 30
sendln 'stop 5'
