; A. Description
;    A list of commands here configures ADC and generates non-maskable multiple capture interrupt through timer1 trigger sources.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PE2 (AN16)
;    2. Timer15 : PC0 (Output/Capture Input/External Clock Input)
;
; E. Port Connection
;    1. PC0 (Timer15 Output) ----> PE2 (AN16)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                   : 0
;
; 2. Clock                     : [ 0 p 63 ]
;    Source                    : p (Peripheral Clock)
;    Source Divide             : 63
;
; 3. Config                    : [ config 0 n m 1 8 0 ]
;    Operation                 : n (Non Maskable Interrupt)
;    Mode                      : m (Multiple)
;    Base Trigger Source       : 1 (Timer1)
;    Sequence Count            : 8
;    Sampling Time             : 0
;
; 4. Seq                       : [ 0 1 5 0 16 ]
;    Trigger Source            : 1 (Timer1)
;    Trigger Source Number     : 5 (Timer15)
;    Sequence Number           : 0
;    Input Channel             : 16
;
; Timer1n
; 1. Channel                   : 5 / 1 / 2 (Timer1n)
;
; 2. Clock                     : [ 5 m h 10 1000 ] [ 1 m h 10 1000 ] [ 2 m h 10 1000 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 10
;    Timer1 Pre-Divide         : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                    : [ 5 i p h 320 320 -io o ] [ 1 i p h 960 960 -io o ] [ 2 i p h 640 640 -io o ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 320/960/640
;    B Data                    : 320/960/640
;    Port In/Out (-io)         : o (Output)
;
; 4. Adc Trigger Config        : [ 5 e n ] [ 1 e n ] [ 2 e n ]
;    Enable                    : e (Enable)
;    Mode                      : n (Normal)
;
; PCU (PE)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 2 4 a 7 ]
;    Pin Number                : 4
;    Pin Mode                  : a (Alternative)
;    Alternative               : 7 (AN16)
; 
; PCU (PC0)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 0 a 2 ]
;    Pin Number                : 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (T5IO)
; 
; PCU (PE)
sendln 'cm pcu'
mpause 30
sendln 'port 4 2 a 7'
mpause 30

; PCU (PC)
sendln 'port 2 0 a 2'
mpause 30

; Timer15
sendln 'cm timer1'
mpause 30
sendln 'uninit 5'
mpause 30
sendln 'init 5'
mpause 30
sendln 'clk 5 m h 10 1000'
mpause 30
sendln 'config 5 i p h 320 320 -io o' 
mpause 30
sendln 'adctrg 5 e n'
mpause 30
sendln 'log off'
mpause 30

; Timer11
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 m h 10 1000'
mpause 30
sendln 'config 1 i p h 960 960 -io o' 
mpause 30
sendln 'adctrg 1 e n'
mpause 30

; Timer12
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'clk 2 m h 10 1000'
mpause 30
sendln 'config 2 i p h 640 640 -io o' 
mpause 30
sendln 'adctrg 2 e n'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 63'
mpause 30
sendln 'config 0 n m 1 8 0'
mpause 30
sendln 'seq 0 1 5 0 16'
mpause 30
sendln 'seq 0 1 5 1 1'
mpause 30
sendln 'seq 0 1 5 2 2'
mpause 30
sendln 'seq 0 1 5 3 3'
mpause 30
sendln 'seq 0 1 5 4 4'
mpause 30
sendln 'seq 0 1 5 5 5'
mpause 30
sendln 'seq 0 1 5 6 6'
mpause 30
sendln 'seq 0 1 5 7 7'
mpause 30

; Timer15
sendln 'cm timer1'
mpause 30
sendln 'start 5'
mpause 30

; Timer11
sendln 'start 1'
mpause 30

; Timer12
sendln 'start 2'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'
pause 3 
sendln 'dump 0'
pause 3 
sendln 'stop 0'
mpause 30

; Timer1x
sendln 'cm timer1'
mpause 30
sendln 'stop 5'
mpause 30
sendln 'stop 1'
mpause 30
sendln 'stop 2'
