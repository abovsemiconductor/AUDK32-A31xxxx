; A. Description
;    A list of commands here configures ADC and generates single capture and comparator matched interrupt by Timer10 output signal.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
; 
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PE2 (AN16)
;    2. Timer15 : PC0 (Output/Capture Input/External Clock Input)
;
; E. Port Connection
;    1. PC0 (Timer15 Output) ----> PE2 (AN16)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 63 ]
;    Source                     : p (Peripheral Clock)
;    Source Divide              : 63
;
; 3. Config                     : [ config 0 i s 1 1 0 ]
;    Operation                  : i (Interrupt)
;    Mode                       : s (Single)
;    Base Trigger Source        : 1 (Timer1)
;    Sequence Count             : 1
;    Sampling Time              : 0
;
; 4. Seq                        : [ 0 1 5 0 16 ]
;    Trigger Source             : 1 (Timer1)
;    Trigger Source Number      : 5 (Timer15)
;    Sequence Number            : 0
;    Input Channel              : 16
;
; 5. Cmp                        : [ 0 e 16 -intr e u ]
;    Comparator Enable          : e (Enable)
;    Input Channel              : 16
;    Comparator Data            : 1024
;    Interrupt Enable           : e (Enable)
;    Interrupt Trigger          : u (Input Channel Sampling Data > Comparator Data)
;
; Timer10
; 1. Channel                    : 0 (Timer10)
;
; 2. Clock                      : [ 0 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 0 i p h 1600 1600 -io o ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;    Port In/Out (-io)          : o (Output)
;
; Timer15
; 1. Channel                    : 5 (Timer15)
;
; 2. Clock                      : [ 5 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 5 i p h 1600 1600 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;
; 4. Adc Trigger Config         : [ 5 e n ]
;    Enable                     : e (Enable)
;    Mode                       : n (Normal)
;
; PCU (PE2)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 2 a 7 ]
;    Pin Number                : 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 7 (AN16)
; 
; PCU (PC0)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 0 a 2 ]
;    Pin Number                : 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (T5IO)
; 
; PCU (PE)
sendln 'cm pcu'
mpause 30
sendln 'port 4 2 a 7'
mpause 30

; PCU (PE)
sendln 'port 2 0 a 2'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i p h 1600 1600'
mpause 30

; Timer15
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 5'
mpause 30
sendln 'init 5'
mpause 30
sendln 'clk 5 m h 10 1000'
mpause 30
sendln 'config 5 i p h 1600 1600'
mpause 30
sendln 'adctrg 5 e n'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 63'
mpause 30
sendln 'config 0 i s 1 1 0'
mpause 30
sendln 'seq 0 1 5 0 16'
mpause 30
sendln 'cmp 0 e 16 1024 -intr e u'
mpause 30
sendln 'log on'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'start 0'
mpause 30

; Timer15
sendln 'start 5'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'start 0'
pause 90
sendln 'log off'
mpause 30
sendln 'stop 0'
mpause 30

; Timer1x
sendln 'cm timer1'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'stop 5'
