; A. Description
;    A list of commands here configures ADC and generates single capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
; 
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PA11 (AN14)
;    2. Timer11 : PE7 (Output/Capture Input)
;
; E. Port Connection
;    1. PA11 (AN14) <----> PE7 (Timer11 Output)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 63 ]
;    Source                     : p (Periperhal Clock)
;    Peripheral Clock Divide    : 63 (Divide + 1)
;
; 3. Config                     : [ config 0 i i ]
;    Operation                  : i (Interrupt)
;    Reference Level            : i (Internal VDD)
;
; 4. Seq                        : [ 0 1 0 14 ]
;    Trigger Source             : 1 (Timer1)
;    Trigger Source Number      : 0 (Timer10)
;    Input Channel              : 1
;
; Timer10
; 1. Channel                    : 0 (Timer10)
;
; 2. Clock                      : [ 0 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 48MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 0 i p h 4800 4800 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 4800
;    B Data                     : 4800
;
; Timer11
; 1. Channel                    : 1 (Timer11)
;
; 2. Clock                      : [ 0 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 48MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 0 i p h 9600 9600 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 9600
;    B Data                     : 9600
;
; PCU
; 1. Port Group                 : 4 (PCU Port E)
;
; 2. Port                       : [ 4 7 a 1 ]
;    Pin Number                 : 7
;    Pin Mode                   : a (Alternative)
;    Alternative                : 1 (Timer11 Output)
; 
; PCU (PA)
; 1. Port Group                 : 0 (PCU Port A)
;
; 2. Port                       : [ 0 0 a 3 ] [ 0 1 a 3 ] [ 0 2 a 3 ]
;    Pin Number                 : 0 / 1 / 2
;    Pin Mode                   : a (Alternative)
;    Alternative                : 3 (AN0/AN1/AN2)
;
; PCU
sendln 'cm pcu'
mpause 30
sendln 'port 4 7 a 1'
mpause 30

; PCU (PA)
sendln 'port 0 11 a 3'
mpause 30
sendln 'port 0 1 a 3'
mpause 30
sendln 'port 0 2 a 3'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i p h 4800 4800'
mpause 30

; Timer11
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 m h 10 1000'
mpause 30
sendln 'config 1 i p h 9600 9600'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 63'
mpause 30
sendln 'config 0 i i'
mpause 30
sendln 'seq 0 1 0 14'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'start 0'
mpause 30

; Timer11
sendln 'start 1'
