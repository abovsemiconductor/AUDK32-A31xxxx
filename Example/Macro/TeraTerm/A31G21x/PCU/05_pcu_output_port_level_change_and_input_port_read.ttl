; A. Description
;    A list of commands here configures PCU module and controls a output level of a target port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PD5 (Output)
;               : PE6 (Input)
;
; E. Port Connection
;    1. PD5 (Output) ----> PE6 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PD5)
; 1. Port Group                : 3 (PCU Port D)
;
; 2. Port                      : [ 3 5 o p h ]
;    Pin Number                : 5
;    Pin Mode                  : o (Output)
;    Pin Output Mode           : p (Push-Pull)
;    Pin Level                 : h (High)
;
; 3. Output                    : [ 3 5 l / h ]
;    Pin Number                : 2
;    Pin Level                 : l (Low) / h (High)
;
; PCU (PE6)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 6 i i ]
;    Pin Number                : 6
;    Pin Mode                  : i (input)
;    Pin Output Mode           : i (input)
;
; 3. Input                     : [ 4 6 ]
;    Pin Number                : 6
;
; PCU (PD5)
sendln 'cm pcu'
mpause 30
sendln 'port 3 5 o p h'
mpause 30

; PCU (PE6)
sendln 'port 4 6 i i'
mpause 30

i = 30
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 3 5 l'
    else
        sendln 'output 3 5 h'
    endif
    mpause 30 
    sendln 'input 4 6'
    pause 1
loop
