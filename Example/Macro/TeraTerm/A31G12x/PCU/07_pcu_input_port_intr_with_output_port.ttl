; A. Description
;    A list of commands here configures PCU module and generates input interrupt via the signal from output port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PE3 (Input)
;               : PA8 (Output)
;
; E. Port Connection
;    1. PA8 (Output) ----> PE3 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PE3)
; 1. Port Group                   : 4 (PCU Port E)
;
; 2. Port                         : [ 4 3 i i -intr i e b ]
;    Pin Number                   : 3
;    Pin Mode                     : i (Input)
;    Pin Input Mode               : i (Normal Input)
;    Pin Operation Mode           : i (Interrupt)
;    Pin Interrupt Mode           : e (Edge)
;    Pin Interrupt Trigger Edge   : b (Both Edge)
;    Pin Interrupt Group Number   : 0 (default) / 1
;
; PCU (PA8)
; 1. Port Group                   : 0 (PCU Port A)
;
; 2. Port                         : [ 0 8 o p h ]
;    Pin Number                   : 8
;    Pin Mode                     : o (Output)
;    Pin Output Mode              : p (Push-Pull)
;    Pin Level                    : h (High)
;
; 3. Output                       : [ 0 8 l / h ]
;    Pin Number                   : 8
;    Pin Level                    : l (Low) / h (High)
;
; PCU (PA8)
sendln 'cm pcu'
mpause 30
sendln 'port 0 8 o p h'
mpause 30

; PCU (PE3)
sendln 'port 4 3 i i -intr i e b'
mpause 30

i = 30
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 0 8 l'
    else
        sendln 'output 0 8 h'
    endif
    pause 1
loop
