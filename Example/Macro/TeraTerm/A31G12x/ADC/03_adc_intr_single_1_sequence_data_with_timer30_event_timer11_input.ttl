; A. Description
;    A list of commands here configures ADC and generates single capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
; 
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. Timer3
;    4. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PA2 (AN2)
;    2. Timer11 : PE7 (Output/Capture Input)
;
; E. Port Connection
;    1. PA2 (AN2) <----> PE7 (Timer11 Output)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 63 ]
;    Source                     : p (Periperhal Clock)
;    Peripheral Clock Divide    : 63 (Divide + 1)
;
; 3. Config                     : [ config 0 i i ]
;    Operation                  : i (Interrupt)
;    Reference Level            : i (Internal VDD)
;
; 4. Seq                        : [ 0 3 0 2 ]
;    Trigger Source             : 3 (Timer3)
;    Trigger Source Number      : 0 (Timer30)
;    Input Channel              : 2
;
; Timer30
; 1. Channel                    : 0 (Timer30)
;
; 2. Clock                      : [ 0 p 3999 ]
;    Source                     : p (PCLK)
;    Timer1 Pre-Divide          : 3999 (Pre-Divide + 1)
;
; 3. Config                     : [ 0 i i s 20000 5000 10000 15000 ]
;    Operation                  : i (Interrupt)
;    Mode                       : i (Period/Interval)
;    Output Port Polarity       : s (6-ch)
;    Period Data                : 20000
;    A Data                     : 5000
;    B Data                     : 10000
;    C Data                     : 15000
;
; 4. Adctrg                     : [ 0 0x08 1 ]
;    Adc Trigger Number         : 0x08 (ADC trigger signal by Period Match)
;    Adc Trigger Delay          : 1 (Interrupt down count)
;
; Timer11
; 1. Channel                    : 1 (Timer11)
;
; 2. Clock                      : [ 1 p 0 3999 ]
;    Source                     : p (PCLK)
;    Source Divide              : 0 (Not available)
;    Timer1 Pre-Divide          : 3999 (Pre-Divide + 1)
;
; 3. Config                     : [ 1 i p h 20000 20000 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 20000
;    B Data                     : 20000
;
; PCU
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 7 a 1 ]
;    Pin Number                : 7
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (Timer11 Output)
; 
; PCU (PA2)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 2 a 3 ]
;    Pin Number                : 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (AN2)
;

; PCU
sendln 'cm pcu'
mpause 30
sendln 'port 4 7 a 1'
mpause 30

; PCU (PA2)
sendln 'port 0 2 a 3'
mpause 30


; Timer11
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 p 0 3999'
mpause 30
sendln 'config 1 i p h 20000 20000'
mpause 30

; Timer30
sendln 'cm timer3'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 3999'
mpause 30
sendln 'config 0 i i s 20000 5000 10000 15000'
mpause 30
sendln 'adctrg 0 0x08 1'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 63'
mpause 30
sendln 'config 0 i i'
mpause 30
sendln 'seq 0 3 0 2'
mpause 30
sendln 'log on'
mpause 30

; Timer11
sendln 'cm timer1'
mpause 30
sendln 'start 1'
mpause 30

; Timer30
sendln 'cm timer3'
mpause 30
sendln 'start 0'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'start 0'
