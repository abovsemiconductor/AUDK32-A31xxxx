; A. Description
;    A list of commands here configures timer2 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer2
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer20 : PC0/PC0 (Output/Capture Input)
;               : PC2 (External Clock Input)
;    2. Timer12 : PA5/PA5 (Output/Capture Input)
;               : PA2 (External Clock Input)
;
; E. Port Connection
;    1. PA5 (Timer12 Output) ----> PC2 (Timer20 External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer20
; 1. Channel                   : 0 (Timer20)
;
; 2. Clock                     : [ 0 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer1 Pre-Divide         : 0 (No Pre-Divider available so default 0)
;
; 3. Config                    : [ 0 i p h 2500 2500 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 2500
;    B Data                    : 2500
;
; Timer12
; 1. Channel                   : 2 (Timer12)
;
; 2. Clock                     : [ 2 p 0 3999 ]
;    Source                    : p (PCLK)
;    Source Divide             : 0 (Not available)
;    Timer1 Pre-Divide         : 3999 (Pre-Divide + 1)
;
; 3. Config                    : [ 2 i p h 1 1 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 1
;    B Data                    : 1
;
; PCU
; 1. Port Group                : 0 (PCU Port A) / 2 (PCU Port C)
;
; 2. Port                      : [ 0 5 a 1 ] [ 2 2 a 1 ]
;    Pin Number                : 5 / 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (T12OUT) / 1 (EC20)
;
; PCU (PA5)
sendln 'cm pcu'
mpause 30
sendln 'port 0 5 a 1'
mpause 30

; PCU(PC0)
sendln 'port 2 2 a 1'
mpause 30

; Timer20
sendln 'cm timer2'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 e f 0'
mpause 30
sendln 'config 0 i p h 2500 2500'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
mpause 30

; Timer12
sendln 'cm timer1'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'clk 2 p 0 3999'
mpause 30
sendln 'config 2 i p h 1 1'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 2'
