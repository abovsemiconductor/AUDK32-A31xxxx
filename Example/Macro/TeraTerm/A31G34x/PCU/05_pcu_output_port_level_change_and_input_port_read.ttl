; A. Description
;    A list of commands here configures PCU module and controls a output level of a target port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PB8 (Output)
;               : PB9 (Input)
;
; E. Port Connection
;    1. PB8 (Output) ----> PB9 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PB8)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 8 o p h ]
;    Pin Number                : 8
;    Pin Mode                  : o (Output)
;    Pin Output Mode           : p (Push-Pull)
;    Pin Level                 : h (High)
;
; 3. Output                    : [ 0 8 l / h ]
;    Pin Number                : 8
;    Pin Level                 : l (Low) / h (High)
;
; PCU (PB9)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 9 i i ]
;    Pin Number                : 9
;    Pin Mode                  : i (input)
;    Pin Output Mode           : i (input)
;
; 3. Input                     : [ 1 9 ]
;    Pin Number                : 9
;
; PCU (PB8)
sendln 'cm pcu'
mpause 30
sendln 'port 1 8 o p h'
mpause 30

; PCU (PB9)
sendln 'port 1 9 i i'
mpause 30

i = 30
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 1 8 l'
    else
        sendln 'output 1 8 h'
    endif
    mpause 30 
    sendln 'input 1 9'
    pause 1
loop
