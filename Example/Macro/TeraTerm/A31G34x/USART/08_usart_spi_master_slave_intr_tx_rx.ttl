; A. Description
;    A list of commands here configures USART as SPI and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART1  : PA3 (Slave Select)
;               : PA4 (Serial Clock)
;               : PA5 (Master Out Slave In)
;               : PA6 (Master In Slave Out)
;    2. USART2  : PE5 (Slave Select)
;               : PE4 (Serial Clock)
;               : PE3 (Master Out Slave In)
;               : PE2 (Master In Slave Out)
;
; E. Port Connection
;    1. PA3 (Slave Select)        <----> PE5 (Slave Select)
;    2. PA4 (Serial Clock)        <----> PE4 (Serial Clock)
;    3. PA5 (Master Out Slave In) <----> PE2 (Master In Slave Out)
;    4. PA6 (Master In Slave Out) <----> PE3 (Master Out Slave In)
;
; For more information, read a user's manual of the target device carefully.
;
; USART1
; 1. Channel                   : 1 (USART1)
;
; 2. Config                    : [ 1 i s m m l e -swap 7 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : s (SPI)
;    SPI Mode                  : m (Master)
;    Bit Order                 : m (MSB)
;    Polarity                  : l (Low)
;    Phase                     : e (Even Edge)
;    Swap MOSI/MISO port       : Swap
;    Baudrate                  : 7
;
; 3. Data                      : [ 1 8 0xff 0xa5 0x5a 0xff 0x01 0x10 0x55 0xaa ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Receive Data Length       : 8
;
; USART2
; 1. Channel                   : 2 (USART2)
;
; 2. Config                    : [ 2 i s s m l e 7 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : s (SPI)
;    SPI Mode                  : s (Slave)
;    Bit Order                 : m (MSB)
;    Polarity                  : l (Low)
;    Phase                     : e (Even Edge)
;    Baudrate                  : 7
;
; 3. Rx                        : [ 2 8 ]
;    Receive Data Length       : 8
;
; PCU (PAx)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 3 a 3 ] [ 0 4 a 3 ] [ 0 5 a 3 ] [ 0 6 a 3 ]
;    Pin Number                : 3 / 4 / 5 / 6
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (SS/SCK/MOSI/MISO)
;
; PCU (PEx)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 5 a 3 ] [ 4 4 a 3 ] [ 4 3 a 3 ] [ 4 2 a 3 ]
;    Pin Number                : 5 / 4 / 3 / 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (SS/SCK/MOSI/MISO)
;
; PCU (PAx)
sendln 'cm pcu'
mpause 30
sendln 'port 0 3 o p h'
mpause 30
sendln 'port 0 4 a 3'
mpause 30
sendln 'port 0 5 a 3'
mpause 30
sendln 'port 0 6 a 3'
mpause 30

; PCU (PEx)
sendln 'port 4 5 a 3'
mpause 30
sendln 'port 4 4 a 3'
mpause 30
sendln 'port 4 3 a 3'
mpause 30
sendln 'port 4 2 a 3'
mpause 30

; USART2
sendln 'cm usart'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'config 2 i s s m l e -swap 7'
mpause 30
sendln 'rx 2 8'
mpause 30

; USART1
sendln 'cm usart'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 i s m m l e 7'
mpause 30
sendln 'data 1 8 0xff 0xa5 0x5a 0xff 0x01 0x10 0x55 0xaa'
mpause 100
sendln 'tx 1 8'
