; A. Description
;    A list of commands here configures SPI module and transmits data via SPI.
;
; B. Preparation
;    Connecting ports with an external SPI device should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. SPI
;    2. PCU/GPIO
;
; D. Default Port
;    1. SPI0    : PE6 (Slave Select)
;               : PE7 (Serial Clock)
;               : PE9 (Master Out Slave In)
;               : PE8 (Master In Slave Out)
;
; For more information, read a user's manual of the target device carefully.
;
; SPI0
; 1. Channel                   : 0 (SPI0)
;
; 2. Config                    : [ 0 i m 8 0 m h 101 ]
;    Operation                 : i (Interrupt)
;    Mode                      : m (Master)
;    Data Length               : 8 (8bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 101 (PCLK / 2 / (Baudrate + 1))
;
; 3. Data                      : [ 0 8 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x09 ]
;    Data Length               : 8
;    Data                      : 0x01 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 0 8 ]
;    Transmit Data Length      : 8
;
; PCU (PEx)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 6 a 3 ] [ 4 7 a 3 ] [ 4 8 a 3 ] [ 4 9 a 3 ]
;    Pin Number                : 6 / 7 / 8 / 9
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (SS0/SCK0/MISO0/MOSI0)
; 
; PCU (PEx)
sendln 'cm pcu'
mpause 30
sendln 'port 4 6 o p h -pupd p'
mpause 30
sendln 'port 4 7 a 3 -pupd p'
mpause 30
sendln 'port 4 8 a 3 -pupd p'
mpause 30
sendln 'port 4 9 a 3 -pupd p'
mpause 30

; SPI0
sendln 'cm spi'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 i m 8 0 m h 101'
mpause 30
sendln 'data 0 8 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x09'
mpause 30
sendln 'tx 0 8'
