; A. Description
;    A list of commands here configures I2C module, and transmits and receives data via I2C.
;
; B. Preparation
;    Connecting ports with an external I2C device should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. I2C
;    2. PCU/GPIO
;
; D. Default Port
;    1. I2C1    : PB1 (Serial Clock)
;               : PB2 (Serial Data)
;    2. I2C2    : PD8 (Serial Clock)
;               : PD9 (Serial Data)
;
; E. Port Connection
;    1. PB1 (Serial Clock) <----> PD8 (Serial Clock)
;    2. PB2 (Serial Data)  <----> PD9 (Serial Data)
;
; For more information, read a user's manual of the target device carefully.
;
; I2C1
; 1. Channel                   : 1 (I2C1)
;
; 2. Config                    : [ 1 d m 400000 ]
;    Operation                 : d (Interrupt DMA)
;    Mode                      : m (Master)
;    Baudrate                  : 400000 (400KHz)
;
; 3. Data                      : [ 1 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0 ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 -saddr 0x49 ]
;    Transmit Data Length      : 8
;    Slave Address             : 0x49 (Hexa Format)
;
; I2C2
; 1. Channel                   : 2 (I2C2)
;
; 2. Config                    : [ 2 d s 400000 -saddr 0x49 ]
;    Operation                 : d (Interrupt DMA)
;    Mode                      : s (Slave)
;    Baudrate                  : 400000 (400KHz)
;    Slave Address             : 0x49 (Hexa Format)
;
; 3. Rx                        : [ 2 8 ]
;    Receive Data Length       : 8
;
; PCU (I2C1)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 1 a 2 -pupd p ] [ 1 2 a 2 -pupd p ]
;    Pin Number                : 1 / 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (SCL/SDA)
;    Pull-up/down              : p (Pull-up)
;
; PCU (I2C2)
; 1. Port Group                : 3 (PCU Port D)
;
; 2. Port                      : [ 3 8 a 2 -pupd p ] [ 3 9 a 2 -pupd p]
;    Pin Number                : 8 / 9 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (SCL/SDA)
;    Pull-up/down              : p (Pull-up)
;
; PCU
sendln 'cm pcu'
mpause 30
sendln 'port 1 1 a 2 -pupd p'
mpause 30
sendln 'port 1 2 a 2 -pupd p'
mpause 30
sendln 'port 3 8 a 2 -pupd p'
mpause 30
sendln 'port 3 9 a 2 -pupd p'
mpause 30

; I2C2
sendln 'cm i2c'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'config 2 d s 400000 -saddr 0x49'
mpause 30
sendln 'rx 2 8'
mpause 100

; I2C1
sendln 'cm i2c'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 d m 400000'
mpause 30
sendln 'data 1 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0'
mpause 30
sendln 'tx 1 8 -saddr 0x49'
