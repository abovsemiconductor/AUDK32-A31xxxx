; A. Description
;    A list of commands here configures timer1 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer1
;    2. Timer2
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer10 : PA0/PA0 (Output/Capture Input)
;               : PA0 (External Clock Input)
;    2. Timer21 : PE1/PE1 (Output/Capture Input)
;               : PE1 (External Clock Input)
;
; E. Port Connection
;    1. PE1 (Timer21 Output) ----> PA0 (Timer10 External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer10
; 1. Channel                   : 2 (Timer10)
;
; 2. Clock                     : [ 2 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer1 Pre-Divide         : 0 (No Pre-Divider available so default 0)
;
; 3. Config                    : [ 2 i p h 1250 1250 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 1250
;    B Data                    : 1250
;
; Timer21
; 1. Channel                   : 0 (Timer21)
;
; 2. Clock                     : [ 0 p 3999 ]
;    Source                    : p (PCLK)
;    Timer1 Pre-Divide         : 3999 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i p h 1 1 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 1
;    B Data                    : 1
;
; PCU (PE1)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 1 a 0 ]
;    Pin Number                : 1
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (T21OUT)
;
; PCU (PA0)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 0 a 4 ]
;    Pin Number                : 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 4 (EC10)

; PCU (PE1)
sendln 'cm pcu'
mpause 30
sendln 'port 4 1 a 0'
mpause 30

; PCU (PA0)
sendln 'port 0 0 a 4'
mpause 30

; Timer21
sendln 'cm timer2'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 p 3999'
mpause 30
sendln 'config 1 i p h 1 1'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 1'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 e f 0'
mpause 30
sendln 'config 0 i p h 1250 1250'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
