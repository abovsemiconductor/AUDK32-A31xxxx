; A. Description
;    A list of commands here configures timer1 and generates a capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer1
;    2. PCU/GPIO
;
; D. Default Port
;    1. Timer10 : PE6/PE6 (Output/Capture Input)
;               : PD7 (External Clock Input)
;    2. Timer11 : PE7/PE7 (Output/Capture Input)
;               : PD6 (External Clock Input)
;
; E. Port Connection
;    1. PE7 (Timer11 Output) ----> PE6 (Timer10 Capture Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer10
; 1. Channel                   : 0 (Timer10)
;
; 2. Clock                     : [ 0 p 0 3999 ]
;    Source                    : p (PCLK)
;    Source Divide             : 0 (Not available)
;    Timer1 Pre-Divide         : 3999 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i c b h 20000 20000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : c (Capture)
;    Capture Egde              : b (Both)
;    Output Port Polarity      : h (High)
;    A Data                    : 20000
;    B Data                    : 20000
;
; Timer11
; 1. Channel                   : 1 (Timer11)
;
; 2. Clock                     : [ 1 p 0 3999 ]
;    Source                    : p (PCLK)
;    Source Divide             : 0 (Not available)
;    Timer1 Pre-Divide         : 3999 (Pre-Divide + 1)
;
; 3. Config                    : [ 1 i p h 10000 10000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 10000
;    B Data                    : 10000
;
; PCU (PE7)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 7 a 1 ]
;    Pin Number                : 7
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (T11OUT)
;
; PCU (PE6)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 6 a 2 ]
;    Pin Number                : 6
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (T10CAP)
;
;

; PCU (PE7)
sendln 'cm pcu'
mpause 30
sendln 'port 4 7 a 1'
mpause 30

; PCU (PE6)
mpause 30
sendln 'port 4 6 a 2'
mpause 30

; Timer11
sendln 'cm timer1'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 p 0 3999'
mpause 30
sendln 'config 1 i p h 10000 10000'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 1'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 0 3999'
mpause 30
sendln 'config 0 i c b h 20000 20000'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
