; A. Description
;    A list of commands here configures timer2 and generates a capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer2
;    2. PCU/GPIO
;
; D. Default Port
;    1. Timer20 : PC0/PC0 (Output/Capture Input)
;               : PC2 (External Clock Input)
;    2. Timer21 : PC1/PC1 (Output/Capture Input)
;               : PC3 (External Clock Input)
;
; E. Port Connection
;    1. PC1 (Timer21 Output) ----> PC0 (Timer20 Capture Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer20
; 1. Channel                   : 0 (Timer20)
;
; 2. Clock                     : [ 0 p 3999 ]
;    Source                    : p (PCLK)
;    Timer2 Pre-Divide         : 3999 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i c b e d h 20000 20000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : c (Capture)
;    Capture Egde              : b (Both)
;    Capture Source            : e (Capture Port Input)
;    Counter Mode              : d (Clear Count)
;    Output Port Polarity      : h (High)
;    A Data                    : 20000
;    B Data                    : 20000
;
; Timer21
; 1. Channel                   : 1 (Timer21)
;
; 2. Clock                     : [ 1 p 3999 ]
;    Source                    : p (PCLK)
;    Timer2 Pre-Divide         : 3999 (Pre-Divide + 1)
;
; 3. Config                    : [ 1 i p h 10000 10000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 10000
;    B Data                    : 10000
;
; PCU
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 1 a 1 ] [ 2 0 a 2 ]
;    Pin Number                : 1 / 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (T21OUT) / 2 (T20CAP)
;
; PCU(PC1)
sendln 'cm pcu'
mpause 30
sendln 'port 2 1 a 1'
mpause 30

; PCU(PC0)
sendln 'port 2 0 a 2'
mpause 30

; Timer21
sendln 'cm timer2'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 p 3999'
mpause 30
sendln 'config 1 i p h 10000 10000'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 1'
mpause 30

; Timer20
sendln 'cm timer2'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 3999'
mpause 30
sendln 'config 0 i c b e d h 20000 20000'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
