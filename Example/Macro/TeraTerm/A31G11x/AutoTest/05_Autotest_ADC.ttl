; A. Description
;    This script automatically executes ADC Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. ADC
;    3. Timer1
;
; C. Port Connection
;    1. ADC/Timer1
;       : PE6 (Output) ----> PA1 (Input)
;       : PE7 (Output) ----> PA2 (Input)
;

timeout=600
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0

getdir mdir
foldercreate 'Result'

fileret='05_Autotest_Result_ADC'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tcadc

fileclose frethnd
dispstr 'End of 5. Auto Test ADC'
end

:tcadc
; ===== START : TestCase ADC =====
dispstr 10 10
dispstr '===== START : TestCase ADC ====='
dispstr 10

ipstr='ADC'
foldercreate ipstr

filestr='01_adc_intr_single_1_sequence_data_with_timer1_input'
chkstr=''
delay=1
NeedReview=1
call dotest
sendln 'stop 0'
pause 1

filestr='02_adc_intr_single_1_sequence_data_with_timer10_event_timer11_input'
chkstr=''
delay=10
NeedReview=1
call dotest
sendln 'stop 0'
mpause 50
sendln 'stop 1'
pause 1

; ===== END : TestCase ADC =====
dispstr 10
dispstr '===== END : TestCase ADC ====='
dispstr 10
return

:dotest
sprintf2 filename '%s\%s\%s.log' mdir ipstr filestr
sprintf2 delfilename '%s\%s.log' ipstr filestr
filedelete delfilename
sprintf2 logstr 'Test %s' filestr
sprintf2 testfile '..\%s\%s.ttl' ipstr filestr
logopen filename 0 0
logwrite logstr
include testfile
pause delay
logclose
call decision
return

:decision
timeout=600
fileopen fhandle filename 0
if NeedReview == 1 then
    resultstr=Reviewstr
else
    filestrseek fhandle chkstr
    if result=0 then
        resultstr=Failstr
    else 
        resultstr=Passstr
    endif
endif

fileseek fhandle 0 0
do
    filereadln fhandle line
    filewriteln frethnd line
loop while result == 0
filewriteln frethnd resultstr
filewriteln frethnd 0
filewriteln frethnd 0
fileclose fhandle
NeedReview=0
resultstr=''
pause 1

return
