; A. Description
;    A list of commands here configures PCU module and sustains a output level of a target port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PA3 (Output)
;               : PB6 (Input)
;
; E. Port Connection
;    1. PA3 (Output) ----> PB6 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PA3)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 3 o p h ]
;    Pin Number                : 3
;    Pin Mode                  : o (Output)
;    Pin Output Mode           : p (Push-Pull)
;    Pin Level                 : h (High)
;
; 3. Output                    : [ 0 3 l / h -sustain e / d ]
;    Pin Number                : 3
;    Pin Level                 : l(Low) / h (High)
;    Pin Sustain Enable        : e (Enable) / d (Disable)
;
; PCU (PB6)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 6 i i ]
;    Pin Number                : 6
;    Pin Mode                  : i (input)
;    Pin Output Mode           : i (input)
;
; 3. Input                     : [ 1 6 ]
;    Pin Number                : 6
;
; PCU (PA3)
sendln 'cm pcu'
mpause 30
sendln 'port 0 3 o p h'
mpause 30
sendln 'output 0 3 h -sustain e'
mpause 30

; PCU (PB6)
sendln 'port 1 6 i i'
mpause 30

i = 10
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 0 3 l'
    else
        sendln 'output 0 3 h'
    endif
    mpause 30
    sendln 'input 1 6'
    pause 1
loop

pause 1
sendln 'output 0 3 l -sustain d'
mpause 30

i = 10
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 0 3 l'
    else
        sendln 'output 0 3 h'
    endif
    mpause 30
    sendln 'input 1 6'
    pause 1
loop

