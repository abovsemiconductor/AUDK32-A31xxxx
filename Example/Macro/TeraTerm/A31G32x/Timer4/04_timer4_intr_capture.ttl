; A. Description
;    A list of commands here configures timer4 and generates a capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer4
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer40 : PC7 (Capture Input 2)
;    2. Timer12 : PA7 (Output)
;
; E. Port Connection
;    1. PA7 (Timer12 Output) ----> PC7 (Timer40 Capture Input 2)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer40
; 1. Channel                   : 0 (Timer40)
;
; 2. Clock                     : [ 0 m h 10 1000 ]
;    Source                    : m ( MCCR : Misc Clock )
;    MCCR Source               : h ( HSI : High Speed Internal Clock - 48MHz )
;    Source Divide             : 10 
;    Timer2 Pre-Divide         : 1000 ( MCCR Clock / 10 ) / 1000
;
; 3. Config                    : [ 0 i c b 2 1 h 4800 4800 ]
;    Operation                 : i (Interrupt)
;    Mode                      : c (Capture)
;    Capture Egde              : b (Both)
;    Capture Source            : 2 (Capture Input 2)
;    Counter Value             : 1 (Prescaler + 1)
;    Output Port Polarity      : h (High)
;    A Data                    : 2400
;    B Data                    : 2400
;
; Timer12
; 1. Channel                   : 2 (Timer12)
;
; 2. Clock                     : [ 2 m h 10 1000 ]
;    Source                    : m ( MCCR : Misc Clock )
;    MCCR Source               : h ( HSI : High Speed Internal Clock - 48MHz )
;    Source Divide             : 10 
;    Timer1 Pre-Divide         : 1000 ( MCCR Clock / 10 ) / 1000
;
; 3. Config                    : [ 2 i p h 4800 4800 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 4800
;    B Data                    : 4800
;
; PCU (PA7)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 7 a 6 ]
;    Pin Number                : 7
;    Pin Mode                  : a (Alternative)
;    Alternative               : 6 (T12OUT)
;
; PCU (PC7)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 7 a 7 ]
;    Pin Number                : 7 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 7 (T40CAP_CH2)

; PCU (PA7)
sendln 'cm pcu'
mpause 30
sendln 'port 0 7 a 6'
mpause 30

; PCU (PC7)
sendln 'port 2 7 a 7'
mpause 30

; Timer12
sendln 'cm timer1'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'clk 2 m h 10 1000'
mpause 30
sendln 'config 2 i p h 4800 4800'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 2'
mpause 30

; Timer40
sendln 'cm timer4'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i c b 2 1 h 2400 2400'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
