; A. Description
;    A list of commands here configures timer3 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer3
;    2. Timer2
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer30 : PA12 (Capture Input/External Clock Input)
;    1. Timer21 : PB0 (Output)
;
; E. Port Connection
;    1. PB0 (Timer21 Output) ----> PA12 (Timer30 Capture Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer30
; 1. Channel                   : 0 (Timer30)
;
; 2. Clock                     : [ 0 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer3 Pre-Divide         : 0 (No Pre-Divider available so default 0)
;
; 3. Config                    : [ 0 i i s 19200 4800 9600 14400 ]
;    Operation                 : i (Interrupt)
;    Mode                      : i (Interval)
;    Output Mode               : s (6-ch)
;    Period                    : 19200
;    A Data                    : 4800
;    B Data                    : 9600
;    C Data                    : 14400
;
; Timer21 
; 1. Channel                   : 1 (Timer21)
;
; 2. Clock                     : [ 1 p 4000 ]
;    Source                    : p (PCLK : Peripheral Clock)
;    Timer2 Pre-Divide         : 4000 (PCLK / 4000)
;
; 3. Config                    : [ 1 i p h 4800 4800 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 4800
;    B Data                    : 4800
;
; PCU (PB0)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 0 a 6 ]
;    Pin Number                : 0 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 6 (T21OUT)
;
; PCU (PA12)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 12 a 3 ]
;    Pin Number                : 12 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (EC30)

; PCU (PB0)
sendln 'cm pcu'
mpause 30
sendln 'port 1 0 a 6'
mpause 30

; PCU (PA12)
sendln 'port 0 12 a 3'
mpause 30

; Timer21
sendln 'cm timer2'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 m h 10 100'
mpause 30
sendln 'config 1 i p h 5 5'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 1'
mpause 30

; Timer30 
sendln 'cm timer3'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 e f 0'
mpause 30
sendln 'config 0 i i s 19200 4800 9600 14400'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
