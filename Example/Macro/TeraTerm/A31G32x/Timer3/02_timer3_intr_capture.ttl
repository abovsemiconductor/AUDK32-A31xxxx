; A. Description
;    A list of commands here configures timer3 and generates a capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer3
;    2. Timer2
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer30 : PA12 (Capture Input/External Clock Input)
;    1. Timer21 : PB0 (Output)
;
; E. Port Connection
;    1. PB0 (Timer21 Output) ----> PA12 (Timer30 Capture Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer30
; 1. Channel                   : 0 (Timer30)
;
; 2. Clock                     : [ 0 m h 10 1000 ]
;    Source                    : m ( MCCR : Misc Clock )
;    MCCR Source               : h ( HSI : High Speed Internal Clock - 48MHz )
;    Source Divide             : 10 
;    Timer3 Pre-Divide         : 1000 ( MCCR Clock / 10 ) / 1000
;
; 3. Config                    : [ 0 i c b s 19200 4800 9600 14400 ]
;    Operation                 : i (Interrupt)
;    Mode                      : c (Capture)
;    Capture Edge              : b (Both Edge)
;    Output Mode               : s (6-ch)
;    Period                    : 19200
;    A Data                    : 4800
;    B Data                    : 9600
;    C Data                    : 14400
;
; Timer21 
; 1. Channel                   : 1 (Timer21)
;
; 2. Clock                     : [ 1 p 4000 ]
;    Source                    : p (PCLK : Peripheral Clock)
;    Timer2 Pre-Divide         : 4000 (PCLK / 4000)
;
; 3. Config                    : [ 1 i p h 4800 4800 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 4800
;    B Data                    : 4800
;
; PCU (PB0)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 0 a 6 ]
;    Pin Number                : 0 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 6 (T21OUT)
;
; PCU (PA12)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 12 a 4 ]
;    Pin Number                : 12 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 4 (T30CAP)

; PCU (PB0)
sendln 'cm pcu'
mpause 30
sendln 'port 1 0 a 6'
mpause 30

; PCU (PA12)
sendln 'port 0 12 a 4'
mpause 30

; Timer21
sendln 'cm timer2'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 p 4000'
mpause 30
sendln 'config 1 i p h 4800 4800'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 1'
mpause 30

; Timer30 
sendln 'cm timer3'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i c b s 19200 4800 9600 14400'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
