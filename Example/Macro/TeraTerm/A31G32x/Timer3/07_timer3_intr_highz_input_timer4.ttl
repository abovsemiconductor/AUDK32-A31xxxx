; A. Description
;    A list of commands here configures timer3 and generates a high-z and a interval interrupt.
;
; B. Preparation
;    N/A
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer3
;    2. Timer4
;
; D. Default Port
;    1. Timer30 : PA8 (PWM AA Output)
;               : PA7 (PWM AB Output)
;               : PA9 (PWM BA Output)
;               : PB0 (PWM BB Output)
;               : PA10 (PWM CA Output)
;               : PB1 (PWM CB Output)
;               : PA12/PA12 (Capture Input/External Clock Input)
;               : PA6 (BLANK Input)
;    1. Timer40 : PA0 (Output)
;               : PB4 (Capture Input 1)
;               : PC7 (Capture Input 2)
;               : PC8 (Capture Input 3)
;               : PC9 (External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer30
; 1. Channel                   : 0 (Timer30)
;
; 2. Clock                     : [ 0 m h 10 1000 ]
;    Source                    : m ( MCCR : Misc Clock )
;    MCCR Source               : h ( HSI : High Speed Internal Clock - 48MHz )
;    Source Divide             : 10 
;    Timer3 Pre-Divide         : 1000 ( MCCR Clock / 10 ) / 1000
;
; 3. Config                    : [ 0 i i s -hiz r t m 19200 4800 9600 14400 ]
;    Operation                 : i (Interrupt)
;    Mode                      : i (Interval)
;    Capture Edge              : b (Both Edge)
;    Output Mode               : s (6-ch)
;    High-Z Edge               : r (Rising)
;    High-Z Source             : t (Timer40 Output)
;    High-Z Interrupt Mode     : m (Maskable)
;    Period                    : 19200
;    A Data                    : 4800
;    B Data                    : 9600
;    C Data                    : 14400
;
; Timer40 
; 1. Channel                   : 0 (Timer40)
;
; 2. Clock                     : [ 0 m h 10 1000 ]
;    Source                    : m ( MCCR : Misc Clock )
;    MCCR Source               : h ( HSI : High Speed Internal Clock - 48MHz )
;    Source Divide             : 10 
;    Timer4 Pre-Divide         : 1000 ( MCCR Clock / 10 ) / 1000
;
; 3. Config                    : [ 0 i p h 4800 4800 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 4800
;    B Data                    : 4800
;
; Timer40
sendln 'cm timer4'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i p h 4800 4800'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'
mpause 30

; Timer30 
sendln 'cm timer3'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i i s -hiz r t m 19200 4800 9600 14400'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
