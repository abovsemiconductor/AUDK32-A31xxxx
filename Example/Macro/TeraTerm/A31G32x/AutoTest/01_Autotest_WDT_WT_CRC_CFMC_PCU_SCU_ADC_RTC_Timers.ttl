; A. Description
;    This script automatically executes WDT, WT, CRC, CFMC, RTC, some of Timer1, some of Timer2, some of Timer3, some of Timer4, ADC, some of PCU, and SCU Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. WDT
;    3. WT
;    4. CRC
;    5. CFMC
;    6. SCU
;    7. Timer1
;    8. Timer2
;    9. Timer3
;    10. Timer4
;    11. ADC
;    12. DAC
;    13. RTC
;
; C. Port Connection
;    1. ADC
;       : PB14 (Timer11 Output) ----> PA1 (AN1)
;       : PA4 (DAC0 DAO) ---> PA2 (AN2)
;    2. PCU
;       : PA0 (Output) ----> PC0 (Input)
;       : PC13 (Output) ----> PB0 (Input)
;       : PC14 (Output) ----> PB1 (Input)
;       : PC15 (Output) ----> PB2 (Input)
;
; D.Note 
;    1. Modify the line '#define __ROM_SIZE 0x00010000' to '#define __ROM_SIZE 0x00020000 in the ac5_a31xxxx.sct file.
;    2. Modify the line '#define __ROM_SIZE 0x00010000' to '#define __ROM_SIZE 0x00020000 in the ac5_a31xxxx.ld file.

timeout=3000
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0

getdir mdir
foldercreate 'Result'

fileret='01_Autotest_Result_WDT_WT_CRC_FMC_PCU_SCU_ADC_TIMER1_TIMER2_TIMER3_TIMER4_RTC'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

;call tcwdt
;call tcwt
;call tccrc
call tcpcu
;call tcscu
;call tctimer1
;call tctimer2
;call tctimer3
;call tctimer4
;call tcrtc
;call tcadc
;call tcfmc

fileclose frethnd
dispstr 'End of 1. Auto Test WDT/WT/CRC/CFMC/PCU/SCU/ADC/Timer1/Timer2/Timer3/Timer4/RTC'
dispstr 10
dispstr 'Must process the remained PCU/SCU TC.'
end

:tcwdt
; ===== START : TestCase WDT =====
dispstr 10 10
dispstr '===== START : TestCase WDT ====='
dispstr 10

ipstr='WDT'
foldercreate ipstr

filestr='01_wdt_intr_maskable_match'
chkstr='WDT : (0) M evt fired'
delay=0
call dotest

filestr='02_wdt_intr_non_maskable_match'
chkstr='WDT : (0) M evt fired'
delay=0
call dotest

filestr='03_wdt_intr_reset'
chkstr='= Executable module list ='
delay=5
call dotest

filestr='04_wdt_intr_underflow'
chkstr='WDT : (0) U evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

; ===== END : TestCase WDT =====
dispstr 10
dispstr '===== END : TestCase WDT ====='
dispstr 10
return

