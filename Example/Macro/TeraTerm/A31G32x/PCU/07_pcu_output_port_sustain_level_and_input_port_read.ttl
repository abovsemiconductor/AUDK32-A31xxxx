; A. Description
;    A list of commands here configures PCU module and sustains a output level of a target port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PC3 (Output)
;               : PC4 (Input)
;
; E. Port Connection
;    1. PC3 (Output) ----> PC4 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PC3)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 3 o p h ]
;    Pin Number                : 3
;    Pin Mode                  : o (Output)
;    Pin Output Mode           : p (Push-Pull)
;    Pin Level                 : h (High)
;
; 3. Output                    : [ 2 3 l / h -sustain e / d ]
;    Pin Number                : 3
;    Pin Level                 : l(Low) / h (High)
;    Pin Sustain Enable        : e (Enable) / d (Disable)
;
; PCU (PC4)
; 1. Port Group                : C (PCU Port C)
;
; 2. Port                      : [ 2 4 i i ]
;    Pin Number                : 4
;    Pin Mode                  : i (input)
;    Pin Output Mode           : i (input)
;
; 3. Input                     : [ 2 4 ]
;    Pin Number                : 4
;
; PCU (PC3)
sendln 'cm pcu'
mpause 30
sendln 'port 2 3 o p h'
mpause 30
sendln 'output 2 3 h -sustain e'
mpause 30
sendln 'port 2 8 a 0'
mpause 30

; PCU (PC4)
sendln 'port 2 4 i i'
mpause 30

i = 10
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 2 3 l'
    else
        sendln 'output 2 3 h'
    endif
    mpause 30
    sendln 'input 2 4'
    pause 1
loop

pause 1
sendln 'output 2 3 l -sustain d'
mpause 30

i = 10
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 2 3 l'
    else
        sendln 'output 2 3 h'
    endif
    mpause 30
    sendln 'input 2 4'
    pause 1
loop

