; A. Description
;    A list of commands here reads/writes data from/to an external SRAM via EBI module.
;	 And it also contains commands to setup EBI.
;
; B. Preparation
;    Connecting ports with SRAM should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. EBI 
;    2. PCU/GPIO
;
; D. Default Port
;    1. EBI     : PB5(AD0)
;               : PB4(AD1)
;               : PB2(AD2)
;               : PA12(AD3)
;               : PA11(AD4)
;               : PA10(AD5)
;               : PA9(AD6)
;               : PA8(AD7)
;               : PB15(AD8)
;               : PA14(AD9)
;               : PA13(AD10)
;               : PA12(AD11)
;               : PA11(AD12)
;               : PA10(AD13)
;               : PB2(AD14)
;               : PB1(AD15)
;               : PB5(AD16)
;               : PC5(AD17)
;               : PC4(AD18)
;               : PA7(AD19)
;               : PA15(ALE)
;               : PC7(UDS)
;               : PC10(LDS)
;               : PC8(UWR)
;               : PC0(LWR)
;               : PA6(RD)
;               : PB7(CS0)
;               : PC6(NWAIT)
;
; For more information, read a user's manual of the target device carefully.
;
; - SRAM Kit (Tested) : IS62WV51216BLL SRAM Board (ISSI)
;
; 1. Config                     : [ 0 m 8 e 1 31 ]
;    Bus Mode                   : m (Muxed)
;    Bus Width                  : 8 (8bit)
;    Byte Lane                  : e (Enable)
;    Keep Address Clock N-Cycle : 1 (1-Cycle)
;    Read/Write N-Wait          : 31 (0 Wait)
;
; 2. Write                      : [ 0 0x60000000 0x5A b ]
;    Address                    : 0x60000000
;    Data                       : 0x5A
;    Data Width                 : b (Byte)
;
; 3. Read                       : [ 0 0x60000000 b ]
;    Address                    : 0x60000000
;    Data Width                 : b (Byte)
;
; PCU
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 1 5 a 9 ] [ 1 4 a 9 ] [ 1 3 a 9 ] [ 0 12 a 9 ] [ 0 11 a 9 ] [ 0 10 a 9 ] [ 0 9 a 9 ] [ 0 8 a 9 ]
;                              : [ 1 15 a 9 ] [ 1 14 a 9 ] [ 1 13 a 9 ] [ 1 12 a 9 ] [ 1 11 a 9 ] [ 1 10 a 9 ] [ 1 2 a 9 ]
;                              : [ 1 1 a 9 ] [ 1 5 a 9 ] [ 2 5 a 9 ] [ 2 4 a 9 ] [ 0 7 a 9 ] [ 0 15 a 9 ] [ 2 7 a 9 ] [ 2 10 a 9 ]
;                              : [ 2 8 a 9 ] [ 2 0 a 9 ] [ 0 6 a 9 ] [ 1 7 a 9 ] [ 2 6 a ] 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 9 (EBI Bus)
; PCU
sendln 'cm pcu'
mpause 30
sendln 'port 1 5 a 9'
mpause 30
sendln 'port 1 5 a 9'
mpause 30
sendln 'port 1 4 a 9'
mpause 30
sendln 'port 1 3 a 9'
mpause 30
sendln 'port 0 12 a 9'
mpause 30
sendln 'port 0 11 a 9'
mpause 30
sendln 'port 0 10 a 9'
mpause 30
sendln 'port 0 9 a 9'
mpause 30
sendln 'port 0 8 a 9'
mpause 30
sendln 'port 1 15 a 9'
mpause 30
sendln 'port 1 14 a 9'
mpause 30
sendln 'port 1 13 a 9'
mpause 30
sendln 'port 1 12 a 9'
mpause 30
sendln 'port 1 11 a 9'
mpause 30
sendln 'port 1 10 a 9'
mpause 30
sendln 'port 1 2 a 9'
mpause 30
sendln 'port 1 1 a 9'
mpause 30
sendln 'port 1 5 a 9'
mpause 30
sendln 'port 2 5 a 9'
mpause 30
sendln 'port 2 4 a 9'
mpause 30
sendln 'port 0 7 a 9'
mpause 30
sendln 'port 0 15 a 9'
mpause 30
sendln 'port 2 7 a 9'
mpause 30
sendln 'port 2 10 a 9'
mpause 30
sendln 'port 2 8 a 9'
mpause 30
sendln 'port 2 0 a 9'
mpause 30
sendln 'port 0 6 a 9'
mpause 30
sendln 'port 1 7 a 9'
mpause 30
sendln 'port 2 6 a 9' 
mpause 30

sendln 'cm ebi'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 m 8 e 1 31'
mpause 30
sendln 'write 0 0x60000000 0x5A b'
pause 1
sendln 'read 0 0x60000000 b'
pause 1
sendln 'read 0 0x60000000 h'
pause 1
sendln 'read 0 0x60000000 w'
pause 1
sendln 'write 0 0x60000000 0xFF b'
pause 1
sendln 'read 0 0x60000000 b'
pause 1
sendln 'read 0 0x60000000 h'
pause 1
sendln 'read 0 0x60000000 w'
pause 1
sendln 'write 0 0x60000000 0xA5 b'
pause 1
sendln 'read 0 0x60000000 b'
pause 1
sendln 'read 0 0x60000000 h'
pause 1
sendln 'read 0 0x60000000 w'
pause 1
sendln 'write 0 0x60000000 0x5A5A h'
pause 1
sendln 'read 0 0x60000000 b'
pause 1
sendln 'read 0 0x60000000 h'
pause 1
sendln 'read 0 0x60000000 w'
pause 1
sendln 'write 0 0x60000000 0xdeaf h'
pause 1
sendln 'read 0 0x60000000 b'
pause 1
sendln 'read 0 0x60000000 h'
pause 1
sendln 'read 0 0x60000000 w'
pause 1
sendln 'write 0 0x60000000 0xA5A5 h'
pause 1
sendln 'read 0 0x60000000 b'
pause 1
sendln 'read 0 0x60000000 h'
pause 1
sendln 'read 0 0x60000000 w'
pause 1
sendln 'write 0 0x60000000 0xdeaf5AA5 w'
pause 1
sendln 'read 0 0x60000000 b'
pause 1
sendln 'read 0 0x60000000 h'
pause 1
sendln 'read 0 0x60000000 w'
pause 1
