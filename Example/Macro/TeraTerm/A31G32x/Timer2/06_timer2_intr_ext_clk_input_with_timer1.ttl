; A. Description
;    A list of commands here configures timer2 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer2
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer21 : PA10 (External Clock Input)
;    2. Timer13 : PB2 (Output)
;
; E. Port Connection
;    1. PB2 (Timer13 Output) ----> PA10 (Timer21 External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer20
; 1. Channel                   : 1 (Timer21)
;
; 2. Clock                     : [ 1 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer1 Pre-Divide         : 0 (No Pre-Divider available so default 0)
;
; 3. Config                    : [ 1 i p h 4800 4800 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 4800 
;    B Data                    : 4800
;
; Timer10
; 1. Channel                   : 3 (Timer13)
;
; 2. Clock                     : [ 3 m h 10 100 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 48MHz)
;    Source Divide             : 10 
;    Timer2 Pre-Divide         : 100 (MCCR Clock / 10) / 100
;
; 3. Config                    : [ 3 i p h 5 5 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 5 
;    B Data                    : 5
;
; PCU (PA10)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 10 a 4 ]
;    Pin Number                : 5 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 4 (EC21)
;
; PCU (PB2)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 2 a 6 ]
;    Pin Number                : 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 6 (T13OUT)

; PCU (PA10)
sendln 'cm pcu'
mpause 30
sendln 'port 0 10 a 4'
mpause 30

; PCU (PB2)
sendln 'port 1 2 a 6'
mpause 30

; Timer21
sendln 'cm timer2'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 e f 0'
mpause 30
sendln 'config 1 i p h 4800 4800'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 1'
mpause 30

; Timer13
sendln 'cm timer1'
mpause 30
sendln 'uninit 3'
mpause 30
sendln 'init 3'
mpause 30
sendln 'clk 3 m h 10 100'
mpause 30
sendln 'config 3 i p h 5 5'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 3'
