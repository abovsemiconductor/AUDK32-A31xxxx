; A. Description
;    A list of commands here configures PCU module and generates input interrupt via the signal from output port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PB6 (Output)
;               : PC0 (Input)
;
; E. Port Connection
;    1. PB6 (Output) ----> PC0 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PC0)
; 1. Port Group                   : 2 (PCU Port C)
;
; 2. Port                         : [ 2 0 i i -intr i e b ]
;    Pin Number                   : 0
;    Pin Mode                     : i (Input)
;    Pin Input Mode               : i (Normal Input)
;    Pin Operation Mode           : i (Interrupt)
;    Pin Interrupt Mode           : e (Edge)
;    Pin Interrupt Trigger Edge   : b (Both Edge)
;    Pin Interrupt Group Number   : 0 (default) / 1
;
; PCU (PB6)
; 1. Port Group                   : 1 (PCU Port B)
;
; 2. Port                         : [ 1 6 o p h ]
;    Pin Number                   : 6
;    Pin Mode                     : o (Output)
;    Pin Output Mode              : p (Push-Pull)
;    Pin Level                    : h (High)
;
; 3. Output                       : [ 1 6 l / h ]
;    Pin Number                   : 6
;    Pin Level                    : l (Low) / h (High)
;
; PCU (PB6)
sendln 'cm pcu'
mpause 30
sendln 'port 1 6 o p h'
mpause 30

; PCU (PC0)
sendln 'port 2 0 i i -intr i e b'
mpause 30

i = 30
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 1 6 l'
    else
        sendln 'output 1 6 h'
    endif
    pause 1
loop
