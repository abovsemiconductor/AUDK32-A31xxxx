; A. Description
;    A list of commands here configures timer1 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer1
;    2. Timer2
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer12 : PC8/PC8 (Output/Capture Input)
;               : PC8 (External Clock Input)
;    2. Timer20 : PB3/PB3 (Output/Capture Input)
;               : PA5 (External Clock Input)
;
; E. Port Connection
;    1. PB3 (Timer20 Output) ----> PC8 (Timer12 External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer12
; 1. Channel                   : 2 (Timer12)
;
; 2. Clock                     : [ 2 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer1 Pre-Divide         : 0 (No Pre-Divider available so default 0)
;
; 3. Config                    : [ 2 i p h 1250 1250 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 1250
;    B Data                    : 1250
;
; Timer20
; 1. Channel                   : 0 (Timer20)
;
; 2. Clock                     : [ 0 p 3999 ]
;    Source                    : p (PCLK)
;    Timer1 Pre-Divide         : 3999 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i p h 1 1 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 1
;    B Data                    : 1
;
; PCU
; 1. Port Group                : 2 (PCU Port C) / 1 (PCU Port B)
;
; 2. Port                      : [ 2 8 a 4 ] [ 1 3 a 0 ]
;    Pin Number                : 8 / 3
;    Pin Mode                  : a (Alternative)
;    Alternative               : 4 (EC12) / 0 (T20OUT);

; PCU (PC8)
sendln 'cm pcu'
mpause 30
sendln 'port 2 8 a 4'
mpause 30

; PCU(PB3)
sendln 'port 1 3 a 0'
mpause 30

; Timer20
sendln 'cm timer2'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 3999'
mpause 30
sendln 'config 0 i p h 1 1'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'
mpause 30

; Timer12
sendln 'cm timer1'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'clk 2 e f 0'
mpause 30
sendln 'config 2 i p h 1250 1250'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 2'
