; A. Description
;    A list of commands here configures USART as SPI and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART2  : PF2 (Slave Select)
;               : PC12 (Serial Clock)
;               : PC4 (Master Out Slave In)
;               : PC5 (Master In Slave Out)
;    2. USART3  : PA15 (Slave Select)
;               : PD4 (Serial Clock)
;               : PA0 (Master Out Slave In)
;               : PA1 (Master In Slave Out)
;
; E. Port Connection
;    1. PF2 (Slave Select)        <----> PA15  (Slave Select)
;    2. PC12 (Serial Clock)        <----> PD4 (Serial Clock)
;    3. PC4 (Master Out Slave In) <----> PA1 (Master In Slave Out)
;    4. PC5 (Master In Slave Out) <----> PA0 (Master Out Slave In)
;
; For more information, read a user's manual of the target device carefully.
;
; USART2
; 1. Channel                   : 2 (USART2)
;
; 2. Config                    : [ 2 i s m m l e -swap 7 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : s (SPI)
;    SPI Mode                  : m (Master)
;    Bit Order                 : m (MSB)
;    Polarity                  : l (Low)
;    Phase                     : e (Even Edge)
;    Swap MOSI/MISO port       : Swap
;    Baudrate                  : 7
;
; 3. Data                      : [ 2 8 0xff 0xa5 0x5a 0xff 0x01 0x10 0x55 0xaa ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 2 8 ]
;    Receive Data Length       : 8
;
; USART3
; 1. Channel                   : 3 (USART3)
;
; 2. Config                    : [ 3 i s s m l e 7 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : s (SPI)
;    SPI Mode                  : s (Slave)
;    Bit Order                 : m (MSB)
;    Polarity                  : l (Low)
;    Phase                     : e (Even Edge)
;    Baudrate                  : 7
;
; 3. Rx                        : [ 3 8 ]
;    Receive Data Length       : 8
;
; PCU (PAx)
; 1. Port Group                : 5 / 2 (PCU Port F/C)
;
; 2. Port                      : [ 5 2 a 2 ] [ 2 12 a 3 ] [ 2 4 a 3 ] [ 2 5 a 3 ]
;    Pin Number                : 2 / 12 / 4 / 5
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2  / 3 (SS/SCK/MOSI/MISO)
;
; PCU (PB/F)
; 1. Port Group                : 0 / 3 / 0 (PCU Port A/D/A)
;
; 2. Port                      : [ 0 15 a 7 ] [ 3 4 a 3 ] [ 0 0 a 3 ] [ 0 1 a 3 ]
;    Pin Number                : 15 / 4 / 0 / 1
;    Pin Mode                  : a (Alternative)
;    Alternative               : 7 / 3 (SS/SCK/MOSI/MISO)
;
; PCU (PB/Ax)
sendln 'cm pcu'
mpause 30
sendln 'port 5 2 o p h'
mpause 30
sendln 'port 2 12 a 3'
mpause 30
sendln 'port 2 4 a 3'
mpause 30
sendln 'port 2 5 a 3'
mpause 30

; PCU (PBx)
sendln 'port 0 15 a 7'
mpause 30
sendln 'port 3 4 a 3'
mpause 30
sendln 'port 0 0 a 3'
mpause 30
sendln 'port 0 1 a 3'
mpause 30

; USART3
sendln 'cm usart'
mpause 30
sendln 'uninit 3'
mpause 30
sendln 'init 3'
mpause 30
sendln 'config 3 i s s m l e -swap 7'
mpause 30
sendln 'rx 3 8'
mpause 30

; USART2
sendln 'cm usart'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'config 2 i s m m l e 7'
mpause 30
sendln 'data 2 8 0xff 0xa5 0x5a 0xff 0x01 0x10 0x55 0xaa'
mpause 100
sendln 'tx 2 8'
