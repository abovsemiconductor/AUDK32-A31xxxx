; A. Description
;    A list of commands here configures USART as USRT and transmits data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART1  : PC12 (Serial Clock)
;               : PC4 (Transmit)
;               : PC5 (Receive)
;
; For more information, read a user's manual of the target device carefully.
;
; USART2
; 1. Channel                   : 2 (USART2)
;
; 2. Config                    : [ 2 i a m 8 n 1 0 38400 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : a (USRT)
;    USRT Mode                 : m (Master)
;    Data Bit                  : 8 (8bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Polarity                  : 0 (Tx Rising and Rx Falling Edge)
;    Baudrate                  : 38400 bps
;
; 3. Data                      : [ 2 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0 ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 2 8 ]
;    Receive Data Length       : 8
;
; PCU (PCx)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 12 a 3 -pupd p ] [ 2 4 a 2 -pupd p ] [ 2 5 a 2 -pupd p ]
;    Pin Number                : 12 / 4 / 5
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 / 2 / 2 (SCK/Tx/Rx)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PCx)
sendln 'cm pcu'
mpause 30
sendln 'port 2 12 a 3 -pupd p'
mpause 30
sendln 'port 2 4 a 2 -pupd p'
mpause 30
sendln 'port 2 5 a 2 -pupd p'
mpause 30

; USART2
sendln 'cm usart'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'config 2 i a m 8 n 1 0 38400'
mpause 30
sendln 'data 2 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0'
mpause 30
sendln 'tx 2 8'
