; A. Description
;    A list of commands here configures USART as UART and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART2  : PC4 (Transmit)
;               : PC5 (Receive)
;    2. USART3  : PA0 (Transmit)
;               : PA1 (Receive)
;
; E. Port Connection
;    1. PC4 (Transmit) <----> PA1 (Receive)
;    2. PC5 (Receive)  <----> PA0 (Transmit)
;
; For more information, read a user's manual of the target device carefully.
;
; USART2
; 1. Channel                   : 2 (USART2)
;
; 2. Config                    : [ 2 d u 8 n 1 n 38400 ]
;    Operation                 : d (DMA)
;    USART Mode                : u (UART)
;    Data Bit                  : 8 (8bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Speed Mode                : n (Normal)
;    Baudrate                  : 38400 bps
;
; 3. Data                      : [ 2 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0 ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 2 8 ]
;    Receive Data Length       : 8
;
; USART3
; 1. Channel                   : 3 (USART3)
;
; 2. Config                    : [ 3 d u 8 n 1 n 38400 ]
;    Operation                 : d (Interrupt)
;    USART Mode                : u (UART)
;    Data Bit                  : 8 (8bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Speed Mode                : n (Normal)
;    Baudrate                  : 38400 bps
;
; 3. Rx                        : [ 3 8 ]
;    Receive Data Length       : 8
;
; PCU (PAx)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 0 a 2 -pupd p ] [ 0 1 a 2 -pupd p ]
;    Pin Number                : 0 / 1
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (Tx/Rx)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PCx)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 4 a 2 -pupd p ] [ 2 5 a 2 -pupd p ]
;    Pin Number                : 4 / 5
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (Tx/Rx)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PAx)
sendln 'cm pcu'
mpause 30
sendln 'port 0 0 a 2 -pupd p'
mpause 30
sendln 'port 0 1 a 2 -pupd p'
mpause 30

; PCU (PCx)
sendln 'port 2 4 a 2 -pupd p'
mpause 30
sendln 'port 2 5 a 2 -pupd p'
mpause 30

; USART3
sendln 'cm usart'
mpause 30
sendln 'uninit 3'
mpause 30
sendln 'init 3'
mpause 30
sendln 'config 3 d u 8 n 1 n 38400'
mpause 30
sendln 'rx 3 8'
mpause 30

; USART2
sendln 'cm usart'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'config 2 d u 8 n 1 n 38400'
mpause 30
sendln 'data 2 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0'
mpause 100
sendln 'tx 2 8'
