; A. Description
;    A list of commands here configures USART as UART and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART1  : PA0 (Transmit)
;               : PA1 (Receive)
;
; For more information, read a user's manual of the target device carefully.
;
; USART3
; 1. Channel                   : 3 (USART3)
;
; 2. Config                    : [ 3 i u 8 n 1 n 38400 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : u (UART)
;    Data Bit                  : 8 (8bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Speed Mode                : n (Normal)
;    Baudrate                  : 38400 bps
;
; 3. Rx                        : [ 3 8 ]
;    Receive Data Length       : 8
;
; PCU (PAx)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 0 a 2 -pupd p ] [ 0 1 a 2 -pupd p ]
;    Pin Number                : 0 / 1 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (TX/RX)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PAx)
sendln 'cm pcu'
mpause 30
sendln 'port 0 0 a 2 -pupd p'
mpause 30
sendln 'port 0 1 a 2 -pupd p'
mpause 30

; USART3
sendln 'cm usart'
mpause 30
sendln 'uninit 3'
mpause 30
sendln 'init 3'
mpause 30
sendln 'config 3 i u 8 n 1 n 38400'
mpause 30
sendln 'rx 3 8'
