; A. Description
;    A list of commands here configures SCU CLK and generates a certain frequency of PLL Clock.
;
; B. Preparation
;    Make an environment to measure clock frequency by clock output port.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. SCUCLK
;    2. PCU/GPIO
;
; D. Default Port
;    1. PCU    : PD4 (Clock Output)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PD4)
; 1. Port                        : [ 3 4 a 4 ]
;    Port Group Number           : 3 (D group)
;    Pin Number                  : 4
;    Pin Mode                    : Alternative (Mux)
;    Pin Alt Number              : 4
;
; SCUCLK
; 1. Clkout                      : [ m 0 e ]
;    Clock Source                : m (MCLK : Main Clock)
;    Clock Source Divide         : 0
;    Clock Output Enable         : e (Enable)
;
; 2. PLL                         : [ e h 8 1 0 0 15 s 10 2 ]
;    Enable                      : e (Enable)
;    Clock Source                : h (HSI : High Speed Internal Clock) ( 32MHz )
;    Clock Divide                : 8, don't care (not used)
;    PLL Pre-divide (R)          : 15
;    PLL Divide 1   (N1)         : 0
;    PLL Divide 2   (N2)         : 0
;    PLL Feedback Divide (FB)    : 15
;    PLL VCO (Freq Doubler) (D)  : s (VCO), don't care (not used)
;    PLL Current                 : 10, don't care (not used)
;    PLL Bias                    : 2 (none), don't care (not used)
;
;                    ( FIN * ( FB + 1 ))
;    Fout = --------------------------------------
;            (( R + 1 ) * ( N1 + 1 ) * ( N2 + 1 ))
;
; ex) pll e h 8 1 0 0 15 s 10 2 ( HSI 32MHz )
;
;               (32000000 * ( 15 + 1 ))
;    Fout = --------------------------------------,    Fout = 32MHz
;            (( 15 + 1 ) * ( 0 + 1 ) * ( 0 + 1 ))
;
; ex) pll e e 4 3 0 0 15 s 10 2 ( HSE 8MHz )
;
;                (8000000 * ( 15 + 1 ))
;    Fout = --------------------------------------,    Fout = 32MHz
;             (( 3 + 1 ) * ( 0 + 1 ) * ( 0 + 1 ))
;
;
; PCU (PD4)
sendln 'cm pcu'
mpause 30
sendln 'port 3 4 a 4'
mpause 30

; SCUCLK
sendln 'cm scuclk'
mpause 30
sendln 'clkout m 0 e'
mpause 30

; PLL configuration 32MHz 
sendln 'pll e h 8 15 0 0 15 s 10 2'
pause 5
sendln 'pll e e 4 3 0 0 15 s 10 2'

