; A. Description
;    A list of commands here configures SPI module and receives data via SPI.
;
; B. Preparation
;    Connecting ports with an external SPI device should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. SPI
;    2. PCU/GPIO
;
; D. Default Port
;    1. SPI0    : PA4 (Slave Select)
;               : PA5 (Serial Clock)
;               : PA7 (Master Out Slave In)
;               : PA6 (Master In Slave Out)
;    2. SPI1    : PB12 (Slave Select)
;               : PB13 (Serial Clock)
;               : PB15 (Master Out Slave In)
;               : PB14 (Master In Slave Out)
;
; E. Port Connection
;    1. PA4 (Slave Select)        <----> PB12 (Slave Select)
;    2. PA5 (Serial Clock)        <----> PB13 (Serial Clock)
;    3. PA7 (Master Out Slave In) <----> PB15 (Master Out Slave In)
;    4. PA6 (Master In Slave Out) <----> PB14 (Master In Slave Out)
;
; For more information, read a user's manual of the target device carefully.
;
; SPI0
; 1. Channel                   : 0 (SPI0)
;
; 2. Config                    : [ 0 d s 8 0 m h 51 ]
;    Operation                 : d (Interrupt DMA)
;    Mode                      : s (Slave)
;    Data Length               : 8 (8bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 51 (PCLK / 2 / (Baudrate + 1))
;
; 3. Rx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; SPI1
; 1. Channel                   : 1 (SPI1)
;
; 2. Config                    : [ 1 d m 8 0 m h 51 ]
;    Operation                 : d (Interrupt DMA)
;    Mode                      : m (Master)
;    Data Length               : 8 (8bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 51 (PCLK / 2 / (Baudrate + 1))
;
; 3. Data                      : [ 1 8 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x09 ]
;    Data Length               : 8
;    Data                      : 0x01 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Transmit Data Length      : 8
;
; PCU (PA)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 4 a 3 ] [ 0 5 a 3 ] [ 0 6 a 3 ] [ 0 7 a 3 ]
;    Pin Number                : 4 / 5 / 6 / 7
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2/3 (SS0/SCK0/MISO0/MOSI0)
; 
; PCU (PB)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 12 a 6 ] [ 1 13 a 3 ] [ 1 14 a 3 ] [ 1 15 a 3 ]
;    Pin Number                : 12 / 13 / 11 / 15
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2/3 (SS1/SCK1/MISO1/MOSI1)
; 
; PCU (PAx)
sendln 'cm pcu'
mpause 30
sendln 'port 0 4 a 2 -pupd p'
mpause 30
sendln 'port 0 5 a 3 -pupd p'
mpause 30
sendln 'port 0 6 a 3 -pupd p'
mpause 30
sendln 'port 0 7 a 3 -pupd p'
mpause 30

; PCU (PBx)
sendln 'port 1 12 o p h -pupd p'
mpause 30
sendln 'port 1 13 a 3 -pupd p'
mpause 30
sendln 'port 1 14 a 3 -pupd p'
mpause 30
sendln 'port 1 15 a 3 -pupd p'
mpause 30

; SPI0
sendln 'cm spi'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 d s 8 0 m h 51'
mpause 30
sendln 'rx 0 8'
mpause 100

; SPI1
sendln 'cm spi'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 d m 8 0 m h 51'
mpause 30
sendln 'data 1 8 0xa5 0x5a 0xa5 0x5a 0xff 0x10 0x01 0x55'
mpause 100
sendln 'tx 1 8'
