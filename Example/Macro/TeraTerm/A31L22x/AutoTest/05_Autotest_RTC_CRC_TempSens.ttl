; A. Description
;    This script automatically executes WDT, WT, CRC, CFMC, some of Timer1, some of Timer2, some of Timer3, ADC, some of PCU, and SCU Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. CRC
;    3. RTC
;    4. TempSens
;
; C. Port Connection
;
; D.Note 
;    1. Should change a value of CONFIG_IRQ_28 to 1 /* 0 : Timer6, 1 : RTC */ at config_a31l22x.h.

timeout=3000
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0

getdir mdir
foldercreate 'Result'

fileret='05_Autotest_Result_CRC_RTC_TEMPSENS'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tccrc
call tctempsens
call tcrtc

fileclose frethnd
dispstr 'End of 5. Auto Test CRC/RTC/TempSens'
end

:tcwdt
; ===== START : TestCase WDT =====
dispstr 10 10
dispstr '===== START : TestCase WDT ====='
dispstr 10

ipstr='WDT'
foldercreate ipstr

filestr='01_wdt_intr_maskable_match'
chkstr='WDT : (0) M evt fired'
delay=5
call dotest

filestr='03_wdt_intr_reset'
chkstr='= Executable module list ='
delay=12
call dotest

filestr='04_wdt_intr_underflow'
chkstr='WDT : (0) U evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

; ===== END : TestCase WDT =====
dispstr 10
dispstr '===== END : TestCase WDT ====='
dispstr 10
return

:tccrc
; ===== START : TestCase CRC =====
dispstr 10 10
dispstr '===== START : TestCase CRC ====='
dispstr 10

ipstr='CRC'
foldercreate ipstr

filestr='01_crc_poll_poly_8'
chkstr='0x8f'
delay=1
call dotest

filestr='02_crc_poll_poly_16'
chkstr='0x826e'
delay=1
call dotest

filestr='03_crc_poll_poly_16_ccitt'
chkstr='0x7969'
delay=1
call dotest

filestr='04_crc_poll_poly_32'
chkstr='0xccdcd51e'
delay=1
call dotest

filestr='05_checksum_poll'
chkstr='0x165'
delay=1
call dotest

filestr='06_crc_poll_poly_32_8bit'
chkstr='0xccdcd51e'
delay=1
call dotest

filestr='07_crc_poll_poly_32_16bit'
chkstr='0xccdcd51e'
delay=1
call dotest

filestr='08_crc_poll_poly_32_complement'
chkstr='0xccdcd51e'
delay=1
call dotest

; ===== END : TestCase CRC =====
dispstr 10
dispstr '===== END : TestCase CRC ====='
dispstr 10
return

