; A. Description
;    A list of commands here configures CMP and generates both edge detected interrupt.
;
; B. Preparation
;    Supply reference and source signal to specific port by a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. CMP
;    2. Timer4E
;    3. PCU/GPIO
;
; D. Default Port
;    1. CMP0    : PA1 (CP0P0)
;    2. Timer4E : PA7 (Output B)
;
; E. Port Connection
;    1. PA7 (Timer4E3 Output A) ----> PA1 (CP0P0)
;
; For more information, read a user's manual of the target device carefully.
;
; CMP0
; 1. Config                     : [ 0 i m 0 7 h b -dbc 6 0 d -ext m d e 7 ]
;    Operation                  : i (Interrupt)
;    Interrupt Mode             : m (Maskable)
;    Source                     : 0 (CP0P0)
;    Reference                  : 7 (INTREF)
;    Hysteresis                 : h (High)
;    Trigger Mode               : b (both edge)
;    Debounce/Noise Filter (-dbc)     
;    Clock Divide               : 6
;    Debounce Count             : 0 (No Count avaiable so default 0)
;    LSI Clock Enable           : d (No LSI Clock available so default d)
;    Extend Option (-ext)     
;    Power Mode                 : m (No power mode available so default 0)
;    Window Enable              : d (No window available so default 0)
;    Internal Reference Enable  : e (Enable)
;    Internal Reference Level   : 7 (See User Manual's Comparator Section)
;
; Timer4E3
; 1. Channel                   : 3 (Timer4E3)
;
; 2. Clock                     : [ 3 p 4095 ]
;    Source                    : p (PCLK)
;    Timer4e Pre-Divide        : 4095 (Pre-Divide + 1)
;
; 3. Config                    : [ 3 i i -port -pb en h 20000 10000 10000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : i (Interval)
;    Port                      : -pb (Port B)
;    Port Output Enable        : en (Enable)
;    Port Output Start Level   : h (High)
;    Period                    : 20000
;    A Data                    : 10000
;    B Data                    : 10000
;
; PCU (PA7)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 7 a 0 ]
;    Pin Number                : 7
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (T11OUT)
;
; PCU (PA1)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 1 a 5 ]
;    Pin Number                : 1
;    Pin Mode                  : a (Alternative)
;    Alternative               : 5 (CP0P0)
;
; PCU (PA7)
sendln 'cm pcu'
mpause 30
sendln 'port 0 7 a 0'
mpause 30

; PCU (PA1)
sendln 'port 0 1 a 5'
mpause 30

; Timer4E0
sendln 'cm timer4e'
mpause 30
sendln 'uninit 3'
mpause 30
sendln 'init 3'
mpause 30
sendln 'clk 3 p 4095'
mpause 30
sendln 'config 3 i i -port -pb en h 20000 10000 10000'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 3'
mpause 30

; CMP0
sendln 'cm cmp'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 i m 0 7 h b -dbc 6 0 d -ext m d e 7'
mpause 30
sendln 'log on 0'
mpause 30
sendln 'start 0'
