; A. Description
;    A list of commands here configures timer5 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer4E
;    2. Timer5
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer50 : PD3 (Output)
;               : PD4 (Capture Input)
;               : PD5 (External Clock Input)
;    2. Timer4E3 : PA6/PA7/PA6 (OutputA/B/Capture Input)
;                : PA6 (External Clock Input)
;
; E. Port Connection
;    1. PA7 (Timer4E3 Output) ----> PD5 (Timer50 External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer50
; 1. Channel                   : 0 (Timer50)
;
; 2. Clock                     : [ 0 e f ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;
; 3. Config                    : [ 0 i p h 9 9 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 9
;    B Data                    : 9
;
; Timer4E3
; 1. Channel                   : 3 (Timer4E3)
;
; 2. Clock                     : [ 3 p 4095 ]
;    Source                    : p (PCLK)
;    Timer4e Pre-Divide        : 4095 (Pre-Divide + 1)
;
; 3. Config                    : [ 3 i i -port -pb en h 7812 3906 3906 ]
;    Operation                 : i (Interrupt)
;    Mode                      : i (Interval)
;    Port                      : -pb (Port B)
;    Port Output Enable        : en (Enable)
;    Port Output Start Level   : h (High)
;    Period                    : 7814
;    A Data                    : 3907
;    B Data                    : 3907
;
; PCU (PA7)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 7 a 0 ]
;    Pin Number                : 7
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (T4E3OUT)
;
; PCU (PD5)
; 1. Port Group                : 3 (PCU Port D)
;
; 2. Port                      : [ 3 5 a 1 ]
;    Pin Number                : 5 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (EC50)

; PCU (PA7)
sendln 'cm pcu'
mpause 30
sendln 'port 0 7 a 0'
mpause 30

; PCU(PD5)
sendln 'port 3 5 a 1'
mpause 30

; Timer4E0
sendln 'cm timer4e'
mpause 30
sendln 'uninit 3'
mpause 30
sendln 'init 3'
mpause 30
sendln 'clk 3 p 4095'
mpause 30
sendln 'config 3 i i -port -pb en h 7812 3906 3906'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 3'
mpause 30

; Timer50
sendln 'cm timer5'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 e f'
mpause 30
sendln 'config 0 i p h 9 9'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
