; A. Description
;    A list of commands here configures UART and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. UART
;    2. PCU/GPIO
;
; D. Default Port
;    1. UART0   : PE2 (Transmit)
;               : PE3 (Receive)
;
; E. Port Connection
;    1. PE2 (Transmit)
;    2. PE3 (Receive)
;
; For more information, read a user's manual of the target device carefully.
;
; UART0
; 1. Channel                   : 0 (UART0)
;
; 2. CLK                       : [ 0 p ]
;    Clock Source              : p (PCLK : Peripheral Clock Source)
;
; 3. Config                    : [ 0 i 8 o 1 38400 ]
;    Operation                 : i (Interrupt)
;    Data Bit                  : 8 (8bit)
;    Parity                    : o (odd)
;    Stop Bit                  : 1 (1bit)
;    Baudrate                  : 38400 bps
;
; 4. Rx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; PCU (PEx)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 2 a 2 -pupd p ] [ 4 3 a 2 -pupd p ]
;    Pin Number                : 2 / 3 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (TX/RX)
;    Pull-up/down              : p (Pull-up)

; PCU (PCx)
sendln 'cm pcu'
mpause 30
sendln 'port 4 2 a 2 -pupd p'
mpause 30
sendln 'port 4 3 a 2 -pupd p'
mpause 30

; UART0
sendln 'cm uart'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p'
mpause 30
sendln 'config 0 i 8 o 1 38400'
mpause 30
sendln 'rx 0 8'
