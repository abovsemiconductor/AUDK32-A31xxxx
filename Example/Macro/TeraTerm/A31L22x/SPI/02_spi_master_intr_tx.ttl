; A. Description
;    A list of commands here configures SPI module and transmits data via SPI.
;
; B. Preparation
;    Connecting ports with an external SPI device should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. SPI
;    2. PCU/GPIO
;
; D. Default Port
;    1. SPI0    : PA4 (Slave Select)
;               : PA5 (Serial Clock)
;               : PA7 (Master Out Slave In)
;               : PA6 (Master In Slave Out)
;
; For more information, read a user's manual of the target device carefully.
;
; SPI0
; 1. Channel                   : 0 (SPI0)
;
; 2. Config                    : [ 0 i m 8 0 m h 51 ]
;    Operation                 : i (Interrupt)
;    Mode                      : m (Master)
;    Data Length               : 8 (8bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 51 (PCLK / 2 / (Baudrate + 1))
;
; 3. Data                      : [ 0 8 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x09 ]
;    Data Length               : 8
;    Data                      : 0x01 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 0 8 ]
;    Transmit Data Length      : 8
;
; PCU (PAx)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 4 a 2 ] [ 0 5 a 3 ] [ 0 6 a 3 ] [ 0 7 a 3 ]
;    Pin Number                : 4 / 5 / 6 / 7
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2/3 (SS1/SCK1/MISO1/MOSI1)
; 
; PCU (PAx)
sendln 'cm pcu'
mpause 30
sendln 'port 0 4 o p h -pupd p'
mpause 30
sendln 'port 0 5 a 3 -pupd p'
mpause 30
sendln 'port 0 6 a 3 -pupd p'
mpause 30
sendln 'port 0 7 a 3 -pupd p'
mpause 30

; SPI0
sendln 'cm spi'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 i m 8 0 m h 51'
mpause 30
sendln 'data 0 8 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x09'
mpause 30
sendln 'tx 0 8'
