; A. Description
;    A list of commands here configures SPI module and receives data via SPI.
;
; B. Preparation
;    Connecting ports with an external SPI device should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. SPI
;    2. PCU/GPIO
;
; D. Default Port
;    1. SPI0    : PC4 (Slave Select)
;               : PC3 (Serial Clock)
;               : PC1 (Master Out Slave In)
;               : PC2 (Master In Slave Out)
;    2. SPI1    : PE5 (Slave Select)
;               : PE4 (Serial Clock)
;               : PE2 (Master Out Slave In)
;               : PE3 (Master In Slave Out)
;
; E. Port Connection
;    1. PC4 (Slave Select)        <----> PE5 (Slave Select)
;    2. PC3 (Serial Clock)        <----> PE4 (Serial Clock)
;    3. PC1 (Master Out Slave In) <----> PE2 (Master Out Slave In)
;    4. PC2 (Master In Slave Out) <----> PE3 (Master In Slave Out)
;
; For more information, read a user's manual of the target device carefully.
;
; SPI0
; 1. Channel                   : 0 (SPI0)
;
; 2. Config                    : [ 0 d s 8 0 m h 5 -delay 1 1 1 ]
;    Operation                 : d (DMA)
;    Mode                      : s (Slave)
;    Data Length               : 8 (8bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 5 (PCLK / (Baudrate + 1))
;    Delay Start               : 1
;    Delay Stop                : 1
;    Delay Burst               : 1
;
; 3. Rx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; SPI1
; 1. Channel                   : 1 (SPI1)
;
; 2. Config                    : [ 1 d m 8 0 m h 5 -delay 1 1 1 ]
;    Operation                 : d (DMA)
;    Mode                      : m (Master)
;    Data Length               : 8 (8bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 5 (PCLK / (Baudrate + 1))
;    Delay Start               : 1
;    Delay Stop                : 1
;    Delay Burst               : 1
;
; 3. Data                      : [ 1 8 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x09 ]
;    Data Length               : 8
;    Data                      : 0x01 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Transmit Data Length      : 8
;
; PCU (PCx)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 1 a 3 ] [ 2 2 a 3 ] [ 2 3 a 3 ] [ 2 4 a 3 ]
;    Pin Number                : 1 / 2 / 3 / 4
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (MOSI20/MISO20/SCK20/SS20)
; 
; PCU (PEx)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 2 a 3 ] [ 4 3 a 3 ] [ 4 4 a 3 ] [ 4 5 a 3 ]
;    Pin Number                : 2 / 3 / 4 / 5
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (MOSI21/MISO21/SCK21/SS21)
; 
; PCU (PEx)
sendln 'cm pcu'
mpause 30
sendln 'port 2 1 a 3'
mpause 30
sendln 'port 2 2 a 3'
mpause 30
sendln 'port 2 3 a 3'
mpause 30
sendln 'port 2 4 a 3'
mpause 30
sendln 'port 4 2 a 3'
mpause 30
sendln 'port 4 3 a 3'
mpause 30
sendln 'port 4 5 a 3'
mpause 30
sendln 'port 4 4 a 3'
mpause 30

; SPI0
sendln 'cm spi'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 d s 8 0 m h 5 -delay 1 1 1'
mpause 30
sendln 'rx 0 8'
mpause 100

; SPI1
sendln 'cm spi'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 d m 8 0 m h 5 -delay 1 1 1'
mpause 30
sendln 'data 1 8 0xa5 0x5a 0xa5 0x5a 0xff 0x10 0x01 0x55'
mpause 100
sendln 'tx 1 8'
