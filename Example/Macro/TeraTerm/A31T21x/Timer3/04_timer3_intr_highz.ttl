; A. Description
;    A list of commands here configures timer3 and generates a high-z and a interval interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer3
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer30 : PE7 (PWM AA Output)
;               : PE6 (PWM AB Output)
;               : PE5 (PWM BA Output)
;               : PE4 (PWM BB Output)
;               : PE3 (PWM CA Output)
;               : PE2 (PWM CB Output)
;               : PB5 (Capture Input)
;               : PB4 (External Clock Input)
;               : PD4 (BLANK Input)
;    2. Timer13 : PA11/PA11 (Output/Capture Input)
;               : PB11 (External Clock Input)
;
; E. Port Connection
;    1. PA11 (Timer13 Output) ----> PD4 (Timer30 BLANK Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer30
; 1. Channel                   : 0 (Timer30)
;
; 2. Clock                     : [ 0 m h 10 1000 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 10 
;    Timer3 Pre-Divide         : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                    : [ 0 i i s -hiz r e m 12800 3200 6400 9600 ]
;    Operation                 : i (Interrupt)
;    Mode                      : i (Interval)
;    Capture Edge              : b (Both Edge)
;    Output Mode               : s (6-ch)
;    High-Z Edge               : r (Rising)
;    High-Z Source             : e (External Blank)
;    High-Z Interrupt Mode     : m (Maskable)
;    Period                    : 12800
;    A Data                    : 3200
;    B Data                    : 6400
;    C Data                    : 9600
;
; Timer13 
; 1. Channel                   : 3 (Timer13)
;
; 2. Clock                     : [ 3 m h 10 1000 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 10 
;    Timer2 Pre-Divide         : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                    : [ 3 i p h 3200 3200 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 3200
;    B Data                    : 3200
;
; PCU (PD4)
; 1. Port Group                : 3 (PCU Port D)
;
; 2. Port                      : [ 3 4 a 1 ]
;    Pin Number                : 4 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (BLNK)
;
; PCU (PA11)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 11 a 1 ]
;    Pin Number                : 11 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (T13O)

; PCU (PD4)
sendln 'cm pcu'
mpause 30
sendln 'port 3 4 a 1'
mpause 30
sendln 'port 1 5 a 0'
mpause 30
sendln 'port 1 4 a 0'
mpause 30

; PCU (PA11)
sendln 'port 0 11 a 1'
mpause 30

; Timer13
sendln 'cm timer1'
mpause 30
sendln 'uninit 3'
mpause 30
sendln 'init 3'
mpause 30
sendln 'clk 3 m h 10 1000'
mpause 30
sendln 'config 3 i p h 3200 3200'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 3'
mpause 30

; Timer30 
sendln 'cm timer3'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i i s -hiz r e m 12800 3200 6400 9600'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
