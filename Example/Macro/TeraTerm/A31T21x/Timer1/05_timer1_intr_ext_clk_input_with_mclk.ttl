; A. Description
;    A list of commands here configures timer1 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer1
;    2. SCUCLK
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer10 : PE1/PE1 (Output/Capture Input)
;               : PD0 (External Clock Input)
;    2. PCU     : PF2 (Clock Output)
;
; E. Port Connection
;    1. PF2 (Clock Output) ----> PD0 (Timer10 External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer10
; 1. Channel                   : 0 (Timer10)
;
; 2. Clock                     : [ 0 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer1 Pre-Divide         : 0 (No Pre-Divider available so default 0)
;
; 3. Config                    : [ 0 i p h 64000 64000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 64000
;    B Data                    : 64000
;
; PCU (PD0)
; 1. Port Group                : 3 (PCU Port D)
;
; 2. Port                      : [ 3 0 a 2 ]
;    Pin Number                : 0 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (EC10)
;
; PCU (PF4)
; 1. Port Group                : 5 (PCU Port F)
;
; 2. Port                      : [ 5 2 a 3 ]
;    Pin Number                : 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (Clock Output)
;
; SCUCLK
; 1. Clock Out                 : [ clkout m 15 e ]  
;    Clock Source              : m (MCLK - HSI 32MHz)
;    Clock Source Divide       : 15 (Clock Source / (2 * (Divide + 1))
;    Clock Output Enable       : e (Enable)
;
; PCU (PF4)
sendln 'cm pcu'
mpause 30
sendln 'port 5 2 a 3'
mpause 30

; PCU (PD0)
sendln 'port 3 0 a 2'
mpause 30

; SCUCLK
sendln 'cm scuclk'
mpause 30
sendln 'clkout m 15 e'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 e f 0'
mpause 30
sendln 'config 0 i p h 64000 64000'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
