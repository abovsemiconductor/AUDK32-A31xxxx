; A. Description
;    This script automatically executes WDT, CRC, some of PCU, and SCU, FRT, TIMER1, ADC, CMP, CFMC Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. WDT
;    3. CRC
;    4. SCU
;    5. FRT
;    6. TIMER1
;    7. ADC
;    8. CMP
;    9. CFMC
;
; C. Port Connection
;    1. PCU
;       : PC8 (Output)         ----> PC7 (Input)
;       : PE5 (Timer14 Output) ----> PE4 (Input)
;    2. TIMER1
;       : PE7 (Timer11 Output) ----> PE6 (Timer10 Capture Input/External Clock Input)
;    3. CMP
;       : PB9 (Timer18 Output) ----> PA3 (CP0A)
;    4. ADC
;       : PB8 (Timer19 Output) ----> PA8 (AN11)
;

timeout=600
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0

getdir mdir
foldercreate 'Result'

fileret='01_Autotest_Result_WDT_CRC_CFMC_PCU_SCU_FRT_TIMER_CMP_ADC'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tcwdt
call tccrc
call tcpcu
call tcscu
call tcfrt
call tctimer1
call tcadc
call tccmp
call tccfmc

fileclose frethnd
dispstr 'End of 1. Auto Test WDT/CRC/CFMC/PCU/SCU/FRT/TIMER/CMP/ADC'
dispstr 10
dispstr 'Must process the remained PCU/SCU TC.'
end

:tcwdt
; ===== START : TestCase WDT =====
dispstr 10 10
dispstr '===== START : TestCase WDT ====='
dispstr 10

ipstr='WDT'
foldercreate ipstr

filestr='01_wdt_intr_maskable_underflow'
chkstr='WDT : (0) U evt fired'
delay=3
call dotest

filestr='02_wdt_intr_non_maskable_underflow'
chkstr='WDT : (0) U evt fired'
delay=3
call dotest

filestr='03_wdt_intr_reset'
chkstr='= Executable module list ='
delay=12
call dotest

; ===== END : TestCase WDT =====
dispstr 10
dispstr '===== END : TestCase WDT ====='
dispstr 10
return

:tccrc
; ===== START : TestCase CRC =====
dispstr 10 10
dispstr '===== START : TestCase CRC ====='
dispstr 10

ipstr='CRC'
foldercreate ipstr

filestr='01_crc_poll_poly_8'
chkstr='0x8f'
delay=1
call dotest

filestr='02_crc_poll_poly_ccitt'
chkstr='0x7969'
delay=1
call dotest

filestr='03_crc_poll_poly_16'
chkstr='0x826e'
delay=1
call dotest

filestr='04_crc_poll_poly_32'
chkstr='0xccdcd51e'
delay=1
call dotest

filestr='05_crc_dma_poly_32'
chkstr='CRC : (0) result 0xccdcd51e (ISR)'
delay=1
call dotest

filestr='06_crc_dma_non_maskable_poly_32'
chkstr='CRC : (0) result 0xccdcd51e (ISR)'
delay=1
call dotest

; ===== END : TestCase CRC =====
dispstr 10
dispstr '===== END : TestCase CRC ====='
dispstr 10
return

:tccfmc
; ===== START : TestCase CFMC =====
dispstr 10 10
dispstr '===== START : TestCase CFMC ====='
dispstr 10

ipstr='CFMC'
foldercreate ipstr

filestr='01_code_flash'
chkstr='End of Flash'
delay=1
NeedReview=1
call dotest
NeedReview=0

; ===== END : TestCase CFMC =====
dispstr 10
dispstr '===== END : TestCase CFMC ====='
dispstr 10
return

:tcpcu
; ===== START : TestCase PCU =====
dispstr 10 10
dispstr '===== START : TestCase PCU ====='
dispstr 10

ipstr='PCU'
foldercreate ipstr

filestr='02_pcu_input_port_read'
delay=0
NeedReview=1
call dotest
NeedReview=0
pause 1

filestr='03_pcu_input_port_intr_with_timer1'
delay=5
NeedReview=1
call dotest
NeedReview=0
sendln 'stop 4'
pause 1

filestr='04_pcu_output_port_level_change_and_input_port_read'
delay=0
NeedReview=1
call dotest
NeedReview=0
pause 1

filestr='05_pcu_input_port_intr_with_output_port'
delay=0
NeedReview=1
call dotest
NeedReview=0
pause 1

filestr='06_pcu_input_port_intr_non_maskable_with_output_port'
delay=0
NeedReview=1
call dotest
NeedReview=0
pause 1

; ===== END : TestCase PCU =====
dispstr 10
dispstr '===== END : TestCase PCU ====='
dispstr 10
return

:tcscu
; ===== START : TestCase SCU =====
dispstr 10 10
dispstr '===== START : TestCase SCU ====='
dispstr 10

ipstr='SCU'
foldercreate ipstr

filestr='08_scu_reset'
chkstr='= Executable module list ='
delay=3
call dotest
pause 1

; ===== END : TestCase SCU =====
dispstr 10
dispstr '===== END : TestCase SCU ====='
dispstr 10
return

:tcfrt
; ===== START : TestCase FRT =====
dispstr 10 10
dispstr '===== START : TestCase FRT ====='
dispstr 10

ipstr='FRT'
foldercreate ipstr

filestr='01_frt_intr_match'
chkstr='FRT : (0) M evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

filestr='02_frt_intr_overflow'
chkstr='FRT : (0) O(free) evt fired' 
delay=300
call dotest
sendln 'stop 0'
pause 1

filestr='03_frt_intr_non_maskable_match'
chkstr='FRT : (0) M evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

; ===== END : TestCase FRT =====
dispstr 10
dispstr '===== END : TestCase FRT ====='
dispstr 10
return

:tctimer1
; ===== START : TestCase Timer1 =====
dispstr 10 10
dispstr '===== START : TestCase Timer1 ====='
dispstr 10

ipstr='Timer1'
foldercreate ipstr

filestr='01_timer1_intr_period'
chkstr='TIMER1 : (0) P evt fire'
delay=2
call dotest
sendln 'stop 0'
pause 1

filestr='02_timer1_intr_oneshot'
chkstr='TIMER1 : (0) P evt fire'
delay=2
call dotest
sendln 'stop 0'
pause 1

filestr='03_timer1_intr_pwm'
chkstr='TIMER1 : (0) PWM P evt fire'
delay=3
call dotest
sendln 'stop 0'
pause 1

filestr='04_timer1_intr_capture'
chkstr=''
delay=10
NeedReview=1
call dotest
NeedReview=0
sendln 'stop 0'
mpause 30
sendln 'stop 1'
pause 1

filestr='06_timer1_intr_ext_clk_input_with_timer1'
chkstr='TIMER1 : (0) P evt fire'
delay=5
call dotest
sendln 'stop 0'
mpause 30
sendln 'stop 1'
pause 1

filestr='07_timer1_intr_non_maskable_period'
chkstr='TIMER1 : (0) P evt fire'
delay=3
call dotest
sendln 'stop 0'
pause 1

; ===== END : TestCase Timer1 =====
dispstr 10
dispstr '===== END : TestCase Timer1 ====='
dispstr 10
return

