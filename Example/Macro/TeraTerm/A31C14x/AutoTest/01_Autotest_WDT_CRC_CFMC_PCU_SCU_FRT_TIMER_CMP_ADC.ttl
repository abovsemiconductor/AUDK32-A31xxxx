:tccmp
; ===== START : TestCase CMP =====
dispstr 10 10
dispstr '===== START : TestCase CMP ====='
dispstr 10

ipstr='CMP'
foldercreate ipstr

filestr='01_cmp_intr_both_edge_with_timer11'
chkstr='CMP : (0) B evt fired'
delay=3
call dotest
sendln 'cm timer1'
mpause 30
sendln 'stop 8'
mpause 30
sendln 'stop 0'
pause 1

filestr='02_cmp_intr_non_maskable_both_edge_with_timer11'
chkstr='CMP : (0) B evt fired'
delay=3
call dotest
sendln 'cm timer1'
mpause 30
sendln 'stop 8'
mpause 30
sendln 'stop 0'
pause 1

; ===== END : TestCase CMP =====
dispstr 10
dispstr '===== END : TestCase CMP ====='
dispstr 10
return

:dotest
sprintf2 delfilename '%s\%s.log' ipstr filestr
filedelete delfilename
sprintf2 logfilename '%s\%s\%s.log' mdir ipstr filestr
logopen logfilename 0 0
sprintf2 logstr 'Test %s' filestr
logwrite logstr
sprintf2 tcfile '..\%s\%s.ttl' ipstr filestr 
include tcfile
pause delay
logclose
call decision
return

:decision
timeout=600
fileopen fhandle logfilename 0
if NeedReview == 1 then
    resultstr=Reviewstr
else
    filestrseek fhandle chkstr
    if result=0 then
        resultstr=Failstr
    else 
        resultstr=Passstr
    endif
endif

fileseek fhandle 0 0
do
    filereadln fhandle line
    filewriteln frethnd line
loop while result == 0
filewriteln frethnd resultstr
filewriteln frethnd 0
filewriteln frethnd 0
fileclose fhandle
NeedReview=0
resultstr=''
pause 1

return
