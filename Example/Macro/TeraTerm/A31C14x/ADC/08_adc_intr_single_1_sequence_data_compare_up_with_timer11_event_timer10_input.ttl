; A. Description
;    A list of commands here configures ADC and generates single capture and comparator matched interrupt by Timer10 output signal.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
; 
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PA8 (AN11)
;    2. Timer19 : PB8 (Output/Capture Input/External Clock Input)
;
; E. Port Connection
;    1. PB8 (Timer19 Output) ----> PA8 (AN11)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 63 ]
;    Source                     : p (Peripheral Clock)
;    Source Divide              : 63
;
; 3. Config                     : [ config 0 i s 1 1 0 ]
;    Operation                  : i (Interrupt)
;    Mode                       : s (Single)
;    Base Trigger Source        : 1 (Timer1)
;    Sequence Count             : 1
;    Sampling Time              : 0
;
; 4. Seq                        : [ 0 1 1 0 5 ]
;    Trigger Source             : 1 (Timer1)
;    Trigger Source Number      : 1 (Timer19)
;    Sequence Number            : 0
;    Input Channel              : 5
;
; 5. Cmp                        : [ 0 e 11 -intr e u ]
;    Comparator Enable          : e (Enable)
;    Input Channel              : 11 
;    Comparator Data            : 1024
;    Interrupt Enable           : e (Enable)
;    Interrupt Trigger          : u (Input Channel Sampling Data > Comparator Data)
;
; Timer10
; 1. Channel                    : 0 (Timer10)
;
; 2. Clock                      : [ 0 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 0 i p h 1600 1600 -io o ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;    Port In/Out (-io)          : o (Output)
;
; Timer19
; 1. Channel                    : 9 (Timer19)
;
; 2. Clock                      : [ 9 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 9 i p h 1600 1600 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;
; 4. Adc Trigger Config         : [ 9 e n ]
;    Enable                     : e (Enable)
;    Mode                       : n (Normal)
;
; PCU (PA8)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 8 a 7 ]
;    Pin Number                : 8
;    Pin Mode                  : a (Alternative)
;    Alternative               : 7 (AN11)
; 
; PCU (PB8)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 8 a 2 ]
;    Pin Number                : 8
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (T9IO)
; 
; PCU (PA)
sendln 'cm pcu'
mpause 30
sendln 'port 0 8 a 7'
mpause 30

; PCU (PB)
sendln 'port 1 8 a 2'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i p h 1600 1600'
mpause 30

; Timer19
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 9'
mpause 30
sendln 'init 9'
mpause 30
sendln 'clk 9 m h 10 1000'
mpause 30
sendln 'config 9 i p h 1600 1600'
mpause 30
sendln 'adctrg 9 e n'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 63'
mpause 30
sendln 'config 0 i s 1 1 0'
mpause 30
sendln 'seq 0 1 9 0 11'
mpause 30
sendln 'cmp 0 e 11 1024 -intr e u'
mpause 30
sendln 'log on'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'start 0'
mpause 30

; Timer19
sendln 'start 9'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'start 0'
pause 90
sendln 'log off'
mpause 30
sendln 'stop 0'
mpause 30

; Timer1x
sendln 'cm timer1'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'stop 9'
