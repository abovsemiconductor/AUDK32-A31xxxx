; A. Description
;    A list of commands here configures PCU module and generates non-maskable input interrupt via the signal from output port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PC8 (Output)
;               : PC7 (Input)
;
; E. Port Connection
;    1. PC8 (Output) ----> PC7 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PC7)
; 1. Port Group                   : 2 (PCU Port C)
;
; 2. Port                         : [ 2 7 i i -intr n e b ] 
;    Pin Number                   : 7
;    Pin Mode                     : i (Input)
;    Pin Input Mode               : i (Normal Input)
;    Pin Operation Mode           : n (Non Maskable Interrupt)
;    Pin Interrupt Mode           : e (Edge)
;    Pin Interrupt Trigger Edge   : b (Both Edge)
;
; PCU (PC8)
; 1. Port Group                   : 2 (PCU Port C)
;
; 2. Port                         : [ 2 8 o p h ]
;    Pin Number                   : 8
;    Pin Mode                     : o (Output)
;    Pin Output Mode              : p (Push-Pull)
;    Pin Level                    : h (High)
;
; 3. Output                       : [ 2 8 l / h ]
;    Pin Number                   : 8
;    Pin Level                    : l (Low) / h (High)
;
; PCU (PC8)
sendln 'cm pcu'
mpause 30
sendln 'port 2 8 o p h'
mpause 30

; PCU (PC7)
sendln 'port 2 7 i i -intr n e b'
mpause 30

i = 30
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 2 8 l'
    else
        sendln 'output 2 8 h'
    endif
    pause 1
loop
