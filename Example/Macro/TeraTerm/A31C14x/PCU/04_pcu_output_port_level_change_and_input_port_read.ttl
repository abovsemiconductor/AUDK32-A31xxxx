; A. Description
;    A list of commands here configures PCU module and controls a output level of a target port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PC8 (Output)
;               : PC7 (Input)
;
; E. Port Connection
;    1. PC8 (Output) ----> PC7 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PC8)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 8 o p h ]
;    Pin Number                : 8
;    Pin Mode                  : o (Output)
;    Pin Output Mode           : p (Push-Pull)
;    Pin Level                 : h (High)
;
; 3. Output                    : [ 2 8 l / h ]
;    Pin Number                : 8
;    Pin Level                 : l (Low) / h (High)
;
; PCU (PC7)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 7 i i ]
;    Pin Number                : 7
;    Pin Mode                  : i (input)
;    Pin Output Mode           : i (input)
;
; 3. Input                     : [ 2 7 ]
;    Pin Number                : 7
;
; PCU (PC8)
sendln 'cm pcu'
mpause 30
sendln 'port 2 8 o p h'
mpause 30

; PCU (PC7)
sendln 'port 2 7 i i'
mpause 30

i = 30
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 2 8 l'
    else
        sendln 'output 2 8 h'
    endif
    mpause 30 
    sendln 'input 2 7'
    pause 1
loop
