; A. Description
;    A list of commands here configures ADC and generates single capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
; 
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PA1 (AN1)
;    2. Timer12 : PB5 (Output/Capture Input)
;
; E. Port Connection
;    1. PA1 (AN1) <----> PB5 (Timer12 Output)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 31 ]
;    Source                     : p (Periperhal Clock)
;    Peripheral Clock Divide    : 31 (Divide + 1)
;
; 3. Config                     : [ config 0 i i ]
;    Operation                  : i (Interrupt)
;    Reference Level            : i (Internal VDD)
;
; 4. Seq                        : [ 0 1 0 10 ]
;    Trigger Source             : 1 (Timer1)
;    Trigger Source Number      : 0 (Timer10)
;    Input Channel              : 10
;
; Timer10
; 1. Channel                    : 0 (Timer10)
;
; 2. Clock                      : [ 0 p 0 3999 ]
;    Source                     : p (PCLK)
;    Source Divide              : 0 (Not available)
;    Timer1 Pre-Divide          : 3999 (Pre-Divide + 1)
;
; 3. Config                     : [ 0 i p h 10000 10000 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 10000 
;    B Data                     : 10000
;
; Timer12
; 1. Channel                    : 2 (Timer12)
;
; 2. Clock                      : [ 2 p 0 3999 ]
;    Source                     : p (PCLK)
;    Source Divide              : 0 (Not available)
;    Timer1 Pre-Divide          : 3999 (Pre-Divide + 1)
;
; 3. Config                     : [ 2 i p h 20000 20000 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 20000
;    B Data                     : 20000
;
; PCU (PB5)
; 1. Port Group                : 2 (PCU Port B)
;
; 2. Port                      : [ 2 5 a 0 ]
;    Pin Number                : 5
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (T12OUT)
;
; PCU (PA1)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 1 a 0 ]
;    Pin Number                : 1
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (AN1)
;

; PCU (PB5)
sendln 'cm pcu'
mpause 30
sendln 'port 2 5 a 0'
mpause 30

; PCU (PA1)
sendln 'port 0 1 a 0'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 0 3999'
mpause 30
sendln 'config 0 i p h 10000 10000'
mpause 30

; Timer12
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'clk 2 p 0 3999'
mpause 30
sendln 'config 2 i p h 20000 20000'
mpause 30

; ADC 
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 31'
mpause 30
sendln 'config 0 i i'
mpause 30
sendln 'seq 0 1 0 10'
mpause 30
sendln 'log on'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'start 0'
mpause 30

; Timer12
sendln 'start 2'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'start 0'
