; A. Description
;    A list of commands here configures USART as USRT and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART1  : PC9 (Serial Clock)
;               : PC7 (Transmit)
;               : PC8 (Receive)
;    2. USART2  : PD4 (Serial Clock)
;               : PD5 (Transmit)
;               : PD6 (Receive)
;
; E. Port Connection
;    1. PC9 (Serial Clock) <----> PD4 (Serial Clock)
;    2. PC7 (Transmit)     <----> PD6 (Receive)
;    3. PC8 (Receive)      <----> PD5 (Transmit)
;
; For more information, read a user's manual of the target device carefully.
;
; USART1
; 1. Channel                   : 1 (USART1)
;
; 2. Config                    : [ 1 d a m 8 n 1 0 38400 ]
;    Operation                 : d (DMA)
;    USART Mode                : a (USRT)
;    USRT Mode                 : m (Master)
;    Data Bit                  : 8 (8bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Polarity                  : 0 (Tx Rising and Rx Falling Edge)
;    Baudrate                  : 38400 bps
;
; 3. Data                      : [ 1 8 0xaa 0x55 0x10 0x01 0xff 0x5a 0xa5 0xff ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Receive Data Length       : 8
;
; USART2
; 1. Channel                   : 2 (USART2)
;
; 2. Config                    : [ 2 d a s 8 n 1 0 38400 ]
;    Operation                 : d (DMA)
;    USART Mode                : a (USRT)
;    USRT Mode                 : s (Slave)
;    Data Bit                  : 8 (8bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Polarity                  : 0 (Tx Rising and Rx Falling Edge)
;    Baudrate                  : 38400 bps
;
; 3. Rx                        : [ 2 8 ]
;    Receive Data Length       : 8
;
; PCU (PCx)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 9 a 2 ] [ 2 7 a 2 ] [ 2 8 a 2 ]
;    Pin Number                : 9 / 7 / 8
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (SCK/Tx/Rx)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PDx)
; 1. Port Group                : 3 (PCU Port D)
;
; 2. Port                      : [ 3 4 a 3 ] [ 3 6 a 3 ] [ 3 5 a 3 ]
;    Pin Number                : 4 / 6 / 5
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (SCK/Tx/Rx)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PCx)
sendln 'cm pcu'
mpause 30
sendln 'port 2 9 a 3'
mpause 30
sendln 'port 2 7 a 4'
mpause 30
sendln 'port 2 8 a 4'
mpause 30

; PCU (PDx)
sendln 'port 3 4 a 3'
mpause 30
sendln 'port 3 6 a 4'
mpause 30
sendln 'port 3 5 a 4'
mpause 30

; USART2
sendln 'cm usart'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'config 2 d a s 8 n 1 0 38400'
mpause 30
sendln 'rx 2 8'
mpause 30

; USART1
sendln 'cm usart'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 d a m 8 n 1 0 38400'
mpause 30
sendln 'data 1 8 0xaa 0x55 0x10 0x01 0xff 0x5a 0xa5 0xff'
mpause 30
sendln 'tx 1 8'
