; A. Description
;    A list of commands here configures USART as SPI and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART1  : PC10 (Slave Select)
;               : PC9 (Serial Clock)
;               : PC7 (Master Out Slave In)
;               : PC8 (Master In Slave Out)
;    2. USART2  : PB6 (Slave Select)
;               : PD4 (Serial Clock)
;               : PD5 (Master Out Slave In)
;               : PD6 (Master In Slave Out)
;
; E. Port Connection
;    1. PC10 (Slave Select)       <----> PB6 (Slave Select)
;    2. PC9 (Serial Clock)        <----> PD4 (Serial Clock)
;    3. PC7 (Master Out Slave In) <----> PD6 (Master In Slave Out)
;    4. PC8 (Master In Slave Out) <----> PD5 (Master Out Slave In)
;
; For more information, read a user's manual of the target device carefully.
;
; USART1
; 1. Channel                   : 1 (USART1)
;
; 2. Config                    : [ 1 i s m m l o -swap 11 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : s (SPI)
;    SPI Mode                  : s (Slave)
;    Bit Order                 : m (MSB)
;    Polarity                  : l (Low)
;    Phase                     : o (Odd Edge)
;    Swap MOSI/MISO port       : Swap
;    Baudrate                  : 11
;
; 3. Data                      : [ 1 8 0xff 0xa5 0x5a 0xff 0x01 0x10 0x55 0xaa ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Receive Data Length       : 8
;
; USART2
; 1. Channel                   : 2 (USART2)
;
; 2. Config                    : [ 2 i s s m l o -swap 11 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : s (SPI)
;    SPI Mode                  : s (Slave)
;    Bit Order                 : m (MSB)
;    Polarity                  : l (Low)
;    Phase                     : o (Odd Edge)
;    Baudrate                  : 11
;
; 3. Rx                        : [ 2 8 ]
;    Receive Data Length       : 8
;
; PCU (PCx)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 10 a 2 ] [ 2 9 a 2 ] [ 2 7 a 2 ] [ 2 8 a 2 ]
;    Pin Number                : 10 / 9 / 7 / 8
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (SS/SCK/MOSI/MISO)
;
; PCU (PB/Dx)
; 1. Port Group                : 1 / 3 (PCU Port B / D)
;
; 2. Port                      : [ 1 6 a 5 ] [ 3 4 a 3 ] [ 3 6 a 3 ] [ 3 5 a 3 ]
;    Pin Number                : 6 / 4 / 6 / 5
;    Pin Mode                  : a (Alternative)
;    Alternative               : 5 / 3 (SS/SCK/MOSI/MISO)
;
; PCU (PCx)
sendln 'cm pcu'
mpause 30
sendln 'port 2 10 o p h'
mpause 30
sendln 'port 2 9 a 3'
mpause 30
sendln 'port 2 7 a 3'
mpause 30
sendln 'port 2 8 a 3'
mpause 30

; PCU (PEx)
sendln 'port 1 6 a 5'
mpause 30
sendln 'port 3 4 a 3'
mpause 30
sendln 'port 3 6 a 3'
mpause 30
sendln 'port 3 5 a 3'
mpause 30

; USART2
sendln 'cm usart'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'config 2 i s s m l o -swap 7'
mpause 30
sendln 'rx 2 8'
mpause 30

; USART1
sendln 'cm usart'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 i s m m l o 7'
mpause 30
sendln 'data 1 8 0xff 0xa5 0x5a 0xff 0x01 0x10 0x55 0xaa'
mpause 100
sendln 'tx 1 8'
