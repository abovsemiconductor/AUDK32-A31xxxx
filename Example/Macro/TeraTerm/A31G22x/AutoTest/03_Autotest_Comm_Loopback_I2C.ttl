; A. Description
;    This script automatically executes I2C Tera Term example scripts.
;    The 02_Autotest_Comm_Loopback_I2C.ttl must be executed before running this script.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. I2C
;
; C. Port Connection
;    1. I2C0/1
;     : PF6 (Serial Clock)        <---->  PA1 (Serial Clock)
;     : PF7 (Serial Data)         <---->  PA0 (Serial Data)
;    -> 1. I2C1/2
;     -> : PC5 (Serial Data)         <---->  PA0 (Serial Data)
;     -> : PC6 (Serial Clock)        <---->  PA1 (Serial Clock)
;
; D. Note
;    Should change a value of CONFIG_IRQ_25 to 0 /* 0 : I2C, 1 : SPI20 */ at config_a31g22x.h

timeout=600
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
Resultstr=''
Resultstrcmp=0
chkstr=''

getdir mdir
foldercreate 'Result'

fileret='03_Autotest_Result_Comm_Loopback_I2C_SPI'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tci2c

fileclose frethnd
dispstr 'End of 3. Auto Test Comm Loopback I2C and SPI'
end

:tci2c
;===== START : TestCase I2C Loopback =====
dispstr 10 10
dispstr '===== START : TestCase I2C Loopback ====='
dispstr 10 

ipstr='I2C'
foldercreate ipstr

filestr='05_i2c_master_slave_intr_tx_rx_sa_0x49'
iprxstr='I2C : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

;===== END : TestCase I2C Loopback =====
dispstr 10
dispstr '===== END : TestCase I2C Loopback ====='
dispstr 10 
return

:dotest
sprintf2 filename '%s\%s\%s.log' mdir ipstr filestr
sprintf2 delfilename '%s\%s.log' ipstr filestr
filedelete delfilename
sprintf2 logstr 'Test %s' filestr
sprintf2 testfile '..\%s\%s.ttl' ipstr filestr
logopen filename 0 0
logwrite logstr
include testfile
pause delay
logclose
call decision
return

:decision
timeout=600
fileopen fhandle filename 0
if Resultstrcmp == 1 then
    call cmpstr
else
    call cmpdata
endif
fileseek fhandle 0 0
do
    filereadln fhandle line
    filewriteln frethnd line
loop while result == 0
filewriteln frethnd resultstr
filewriteln frethnd 0
filewriteln frethnd 0
fileclose fhandle
NeedReview=0
Resultstrcmp=0
resultstr=''
pause 1
return

:cmpstr
if NeedReview == 1 then
    resultstr=Reviewstr
else
    filestrseek fhandle chkstr
    if result=0 then
        resultstr=Failstr
    else 
        resultstr=Passstr
    endif
endif
return

:cmpdata
fileseek fhandle 0 0
sprintf2 parsestr '%s=([a-zA-Z0-9]+)' iprxstr
while 1
    filereadln fhandle line
    if result = 1 then
        break
    endif
    strmatch line parsestr
    if result > 0 then
        dstr = groupmatchstr1
        strinsert Resultstr index dstr
        strlen dstr
        index = index + result
        if Datacnt > MaxDataCnt - 1 then
            break
        endif
        strinsert Resultstr index ' '
        index = index + 1
        Datacnt = Datacnt + 1
    endif
endwhile
;dispstr "Result : "
;dispstr Resultstr
;dispstr 10
;dispstr "Cmp : "
;dispstr Datastr
;dispstr 10
strcompare Resultstr Datastr
if result == 0 then
    resultstr=Passstr
else
    resultstr=Failstr
endif
return
