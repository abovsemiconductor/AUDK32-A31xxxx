; A. Description
;    A list of commands here configures DAC and generates Rx done dma interrupt by specific data.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. DAC
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. DAC0    : PA6 (DAO)
;  
; For more information, read a user's manual of the target device carefully.
;
; DAC0
; 1. Config                     : [ 0 d m i 0 -port 0x01 ]
;    Operation                  : d (Interrupt DMA)
;    Mode                       : m (Manual)
;    Reference Level            : i (Internal VDD)
;    Re-load reference          : 0 (Timer10)
;    Output Port                : 1
;
; Timer10
; 1. Channel                   : 0 (Timer10)
;
; 2. Clock                     : [ 0 m h 10 1000]
;    Source                    : m ( MCCR : Misc Clock )
;    MCCR Source               : h ( HSI : High Speed Internal Clock - 32MHz )
;    Source Divide             : 10 
;    Timer1 Pre-Divide         : 1000 ( MCCR Clock / 10 ) / 1000
;
; 3. Config                    : [ 0 i p h 800 800 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 800
;    B Data                    : 800
;
; PCU (PA6)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 6 a 3 ]
;    Pin Number                : 6
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (DAC Output)
;
; PCU (PE6)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 6 a 1 ]
;    Pin Number                : 6 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (TIMER1_T10)
;
; PCU (PA6)
sendln 'cm pcu'
mpause 30
sendln 'port 0 6 a 3'
mpause 30

; PCU (PE6)
sendln 'port 4 6 a 1'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i p h 800 800'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'
mpause 30

;DAC0
sendln 'cm dac'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 d m i 0 -port 0x01'
mpause 30
sendln 'start 0'
pause 10
sendln 'buf 0 0 10 0xF000 0xE000 0xD000 0xC000 0xB000 0xA000 0x9000 0x8000 0x7000 0x6000'
mpause 30
sendln 'buf 0 10 6 0x5000 0x4000 0x3000 0x2000 0x1000 0x0000'
mpause 30
sendln 'buf 0 16 10 0x1000 0x2000 0x3000 0x4000 0x5000 0x6000 0x7000 0x8000 0x9000 0xA000'
mpause 30
sendln 'buf 0 26 6 0xB000 0xC000 0xD000 0xE000 0xF000 0xFFF0'
mpause 100
sendln 'start 0'

