; A. Description
;    A list of commands here configures ADC and generates single capture and comparator matched interrupt by DAC output signal.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
; 
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. DAC
;    4. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PA0 (AN0)
;               : PA1 (AN1)
;               : PA4 (AN4)
;    2. DAC0    : PA6 (DAO)
;
; E. Port Connection
;    1. PA6 (DAC0 DAO) ---> PA4 (AN4)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 64 ]
;    Source                     : p (Peripheral Clock)
;    Peripheral Clock Divide    : 64
;
; 3. Config                     : [ config 0 i s 1 1 0 ]
;    Operation                  : i (Interrupt)
;    Mode                       : s (Single)
;    Base Trigger Source        : 1 (Timer1)
;    Sequence Count             : 1
;    Sampling Time              : 0
;
; 4. Seq                        : [ 0 1 0 0 4 ]
;    Trigger Source             : 1 (Timer1)
;    Trigger Source Number      : 0 (Timer10)
;    Sequence Number            : 0
;    Input Channel              : 4
;
; 5. Cmp                        : [ 0 e 2 -intr e d ]
;    Comparator Enable          : e (Enable)
;    Input Channel              : 2 
;    Comparator Data            : 3072
;    Interrupt Enable           : e (Enable)
;    Interrupt Trigger          : d (Input Channel Sampling Data <= Comparator Data)
;
; Timer10
; 1. Channel                    : 0 (Timer10)
;
; 2. Clock                      : [ 0 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 0 i p h 1600 1600 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;
; Timer11
; 1. Channel                    : 1 (Timer11)
;
; 2. Clock                      : [ 1 m h 10 1000 ]
;    Source                     : m (MCCR : Misc Clock)
;    MCCR Source                : h (HSI : High Speed Internal Clock - 48MHz)
;    Source Divide              : 10
;    Timer1 Pre-Divide          : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                     : [ 1 i p h 1600 1600 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 1600
;    B Data                     : 1600
;
; DAC0
; 1. Config                     : [ 0 d m i 1 -port 0x01 ]
;    Operation                  : d (Interrupt DMA)
;    Mode                       : m (Manual)
;    Reference Level            : i (Internal VDD)
;    Re-load reference          : 1 (Timer11)
;    Output Port                : 1 (DAC0)
;
; PCU (PA6)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 6 a 3 ]
;    Pin Number                : 6
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (DAC Output)
; 
; PCU (PA4)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 4 a 3 ]
;    Pin Number                : 0 / 1 / 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (AN0/AN1/AN4)
;
; PCU (PA6)
sendln 'cm pcu'
mpause 30
sendln 'port 0 6 a 3'
mpause 30

; PCU (PA4)
sendln 'port 0 4 a 3'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i p h 1600 1600'
mpause 30

; Timer11
sendln 'cm timer1'
mpause 30
sendln 'log off'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 m h 10 1000'
mpause 30
sendln 'config 1 i p h 1600 1600'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 64'
mpause 30
sendln 'config 0 i s 1 1 0'
mpause 30
sendln 'seq 0 1 0 0 4'
mpause 30
sendln 'cmp 0 e 4 3072 -intr e d'
mpause 30
sendln 'log on'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'start 0'
mpause 30

; Timer11
sendln 'start 1'
mpause 30

; DAC0
sendln 'cm dac'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 d m i 1 -port 0x01'
mpause 30
sendln 'start 0'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'start 0'
mpause 30

; DAC0
pause 15
sendln 'cm dac'
mpause 30
sendln 'buf 0 0 10 0xF000 0xE000 0xD000 0xC000 0xB000 0xA000 0x9000 0x8000 0x7000 0x6000'
mpause 100
sendln 'buf 0 10 6 0x5000 0x4000 0x3000 0x2000 0x1000 0x0000'
mpause 100
sendln 'buf 0 16 10 0x1000 0x2000 0x3000 0x4000 0x5000 0x6000 0x7000 0x8000 0x9000 0xA000'
mpause 100
sendln 'buf 0 26 6 0xB000 0xC000 0xD000 0xE000 0xF000 0xFFF0'
mpause 100
sendln 'start 0'
pause 35

sendln 'stop 0'
mpause 30
sendln 'cm adc'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'cm timer1'
mpause 30
sendln 'stop 0'
mpause 30
sendln 'stop 1'
