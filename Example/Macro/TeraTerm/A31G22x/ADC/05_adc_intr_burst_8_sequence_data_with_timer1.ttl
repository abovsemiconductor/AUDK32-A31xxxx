; A. Description
;    A list of commands here configures ADC and generates burst capture interrupt through timer1 trigger source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;
; D. Default Port
;    1. ADC0    : PA0 (AN0)
;               : PA1 (AN1)
;               : PA2 (AN2)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                   : 0
;
; 2. Clock                     : [ 0 p 64 ]
;    Source                    : p (Peripheral Clock)
;    Peripheral Clock Divide   : 64
;
; 3. Config                    : [ config 0 i b 1 8 0 ]
;    Operation                 : i (Interrupt)
;    Mode                      : b (Burst)
;    Base Trigger Source       : 1 (Timer1)
;    Sequence Count            : 8
;    Sampling Time             : 0
;
; 4. Seq                       : [ 0 1 0 0 0 ]
;    Trigger Source            : 1 (Timer1)
;    Trigger Source Number     : 0 (Timer10)
;    Sequence Number           : 0
;    Input Channel             : 0
;
; Timer10
; 1. Channel                   : 0 (Timer10)
;
; 2. Clock                     : [ 0 m h 10 1000]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 10 
;    Timer1 Pre-Divide         : 1000 (MCCR Clock / 10) / 1000
;
; 3. Config                    : [ 0 i p h 320 320 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 320
;    B Data                    : 320
;
; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 10 1000'
mpause 30
sendln 'config 0 i p h 320 320'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 64'
mpause 30
sendln 'config 0 i b 1 8 0'
mpause 30
sendln 'seq 0 1 0 0 0'
mpause 30
sendln 'seq 0 1 0 1 1'
mpause 30
sendln 'seq 0 1 0 2 2'
mpause 30
sendln 'seq 0 1 0 3 3'
mpause 30
sendln 'seq 0 1 0 4 4'
mpause 30
sendln 'seq 0 1 0 5 5'
mpause 30
sendln 'seq 0 1 0 6 6'
mpause 30
sendln 'seq 0 1 0 7 7'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'start 0'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'start 0'
pause 5
sendln 'dump 0'
pause 1
sendln 'stop 0'
mpause 30

sendln 'cm timer1'
mpause 30
sendln 'stop 0'
