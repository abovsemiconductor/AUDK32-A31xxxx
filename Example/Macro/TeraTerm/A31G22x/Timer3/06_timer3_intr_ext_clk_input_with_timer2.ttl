; A. Description
;    A list of commands here configures timer3 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer3
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer30 : PE0 (PWM AA Output)
;               : PE1 (PWM AB Output)
;               : PE2 (PWM BA Output)
;               : PE3 (PWM BB Output)
;               : PE4 (PWM CA Output)
;               : PE5 (PWM CB Output)
;               : PF7 (Capture Input)
;               : PF6 (External Clock Input)
;               : PF5 (BLANK Input)
;    1. Timer14 : PF11/PF11 (Output/Capture Input)
;               : PF9 (External Clock Input)
;
; E. Port Connection
;    1. PF11 (Timer14 Output) ----> PF6 (Timer30 External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer30
; 1. Channel                   : 0 (Timer30)
;
; 2. Clock                     : [ 0 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer3 Pre-Divide         : 0 (No Pre-Divider available so default 0)
;
; 3. Config                    : [ 0 i i s 12800 3200 6400 9600 ]
;    Operation                 : i (Interrupt)
;    Mode                      : i (Interval)
;    Output Mode               : s (6-ch)
;    Period                    : 12800
;    A Data                    : 3200
;    B Data                    : 6400
;    C Data                    : 9600
;
; Timer14
; 1. Channel                   : 4 (Timer14)
;
; 2. Clock                     : [ 4 m h 10 100 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 10 
;    Timer2 Pre-Divide         : 100 (MCCR Clock / 10) / 100
;
; 3. Config                    : [ 4 i p h 5 5 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 5
;    B Data                    : 5
;
; PCU (PF6)
; 1. Port Group                : 5 (PCU Port F)
;
; 2. Port                      : [ 5 6 a 1 ]
;    Pin Number                : 6 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (TIMER30_EC30)
;
; PCU (PF11)
; 1. Port Group                : 5 (PCU Port F)
;
; 2. Port                      : [ 5 11 a 1 ]
;    Pin Number                : 11
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (T14_T14O)

; PCU (PF6)
sendln 'cm pcu'
mpause 30
sendln 'port 5 6 a 1'
mpause 30

; PCU (PF11)
sendln 'port 5 11 a 1'
mpause 30

; Timer14
sendln 'cm timer1'
mpause 30
sendln 'uninit 4'
mpause 30
sendln 'init 4'
mpause 30
sendln 'clk 4 m h 10 100'
mpause 30
sendln 'config 4 i p h 5 5'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 4'
mpause 30

; Timer30 
sendln 'cm timer3'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 e f 0'
mpause 30
sendln 'config 0 i i s 12800 3200 6400 9600'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
