; A. Description
;    A list of commands here configures I2C module, and transmits and receives data via I2C.
;
; B. Preparation
;    Connecting ports with an external I2C device should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. I2C
;    2. PCU/GPIO
;
; D. Default Port
;    1. I2C2    : PC5 (Serial Clock)
;               : PC6 (Serial Data)
;    2. I2C1    : PA1 (Serial Clock)
;               : PA0 (Serial Data)
;
; E. Port Connection
;    1. PC5 (Serial Clock) <----> PA1 (Serial Clock)
;    2. PC6 (Serial Data)  <----> PA0 (Serial Data)
;
; For more information, read a user's manual of the target device carefully.
;
; I2C1
; 1. Channel                   : 1 (I2C1)
;
; 2. Config                    : [ 1 i m 400000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : m (Master)
;    Baudrate                  : 400000 (400KHz)
;
; 3. Data                      : [ 1 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0 ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 -saddr 0x49 ]
;    Receive Data Length       : 8
;    Slave Address             : 0x49 (Hexa Format)
;
; I2C2
; 1. Channel                   : 2 (I2C2)
;
; 2. Config                    : [ 2 i s 400000 -saddr 0x49 ]
;    Operation                 : i (Interrupt)
;    Mode                      : s (Slave)
;    Baudrate                  : 400000 (400KHz)
;    Slave Address             : 0x49 (Hexa Format)
;
; 3. Rx                        : [ 2 8 ]
;    Receive Data Length       : 8
;
; PCU (I2C2)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 5 a 1 -pupd p ] [ 2 6 a 1 -pupd p ]
;    Pin Number                : 5 / 6 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (SCL/SDA)
;    Pull-up/down              : p (Pull-up)
;
; PCU (I2C1)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 0 a 1 -pupd p ] [ 0 1 a 1 -pupd p]
;    Pin Number                : 0 / 1 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (SDA/SCL)
;    Pull-up/down              : p (Pull-up)
;
; PCU
sendln 'cm pcu'
mpause 30
sendln 'port 2 5 a 1 -pupd p'
mpause 30
sendln 'port 2 6 a 1 -pupd p'
mpause 30
sendln 'port 0 0 a 1 -pupd p'
mpause 30
sendln 'port 0 1 a 1 -pupd p'
mpause 30

; I2C2
sendln 'cm i2c'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'config 2 i s 400000 -saddr 0x49'
mpause 30
sendln 'rx 2 8'

; I2C1
sendln 'cm i2c'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 i m 400000'
mpause 30
sendln 'data 1 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0'
mpause 30
sendln 'tx 1 8 -saddr 0x49'
