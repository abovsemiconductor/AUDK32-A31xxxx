; A. Description
;    A list of commands here configures USART as USRT and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART1  : PD4 (Serial Clock)
;               : PD2 (Transmit)
;               : PD3 (Receive)
;    2. USART2  : PE14 (Serial Clock)
;               : PE12 (Transmit)
;               : PE13 (Receive)
;
; E. Port Connection
;    1. PD4 (Serial Clock)  <----> PE14 (Serial Clock)
;    2. PD2 (Transmit)      <----> PE13 (Receive)
;    3. PD3 (Receive)       <----> PE12 (Transmit)
;
; F. Note
;    Should change a value of CONFIG_IRQ_26 to 0  /* 0 : USART12, 1 : USART13, 2 : SPI21 */ at config_a31g22x.h.
;
; For more information, read a user's manual of the target device carefully.
;
; USART1
; 1. Channel                   : 1 (USART1)
;
; 2. Config                    : [ 1 d a m 8 n 1 0 38400 ]
;    Operation                 : d (DMA)
;    USART Mode                : a (USRT)
;    USRT Mode                 : m (Master)
;    Data Bit                  : 8 (8bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Polarity                  : 0 (Tx Rising and Rx Falling Edge)
;    Baudrate                  : 38400 bps
;
; 3. Data                      : [ 1 8 0xaa 0x55 0x10 0x01 0xff 0x5a 0xa5 0xff ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Receive Data Length       : 8
;
; USART2
; 1. Channel                   : 2 (USART2)
;
; 2. Config                    : [ 2 d a s 8 n 1 0 38400 ]
;    Operation                 : d (DMA)
;    USART Mode                : a (USRT)
;    USRT Mode                 : s (Slave)
;    Data Bit                  : 8 (8bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Polarity                  : 0 (Tx Rising and Rx Falling Edge)
;    Baudrate                  : 38400 bps
;
; 3. Rx                        : [ 2 8 ]
;    Receive Data Length       : 8
;
; PCU (PDx)
; 1. Port Group                : 3 (PCU Port D)
;
; 2. Port                      : [ 3 4 a 2 -pupd p ] [ 3 2 a 1 -pupd p ] [ 3 3 a 1 -pupd p ]
;    Pin Number                : 4 / 2 / 3
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 / 1 / 1 (SCK/Tx/Rx)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PEx)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 14 a 2 -pupd p ] [ 4 12 a 1 -pupd p ] [ 4 13 a 1 -pupd p ]
;    Pin Number                : 14 / 12 / 13
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 / 1 / 1 (SCK/Tx/Rx)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PDx)
sendln 'cm pcu'
mpause 30
sendln 'port 3 4 a 2 -pupd p'
mpause 30
sendln 'port 3 2 a 1 -pupd p'
mpause 30
sendln 'port 3 3 a 1 -pupd p'
mpause 30

; PCU (PEx)
sendln 'port 4 14 a 2 -pupd p'
mpause 30
sendln 'port 4 12 a 1 -pupd p'
mpause 30
sendln 'port 4 13 a 1 -pupd p'
mpause 30

; USART2
sendln 'cm usart'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'config 2 d a s 8 n 1 0 38400'
mpause 30
sendln 'rx 2 8'
mpause 30

; USART1
sendln 'cm usart'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 d a m 8 n 1 0 38400'
mpause 30
sendln 'data 1 8 0xaa 0x55 0x10 0x01 0xff 0x5a 0xa5 0xff'
mpause 30
sendln 'tx 1 8'
