; A. Description
;    A list of commands here configures timer1 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer1
;    2. Timer2
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer13 : PF10/PF10 (Output/Capture Input)
;               : PF8 (External Clock Input)
;    2. Timer21 : PC1/PC1 (Output/Capture Input)
;               : PC3 (External Clock Input)
;
; E. Port Connection
;    1. PC1 (Timer21 Output) ----> PF8 (Timer13 External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer13
; 1. Channel                   : 3 (Timer13)
;
; 2. Clock                     : [ 3 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer1 Pre-Divide         : 0 (No Pre-Divider available so default 0)
;
; 3. Config                    : [ 3 i p h 3200 3200 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 3200
;    B Data                    : 3200
;
; Timer21
; 1. Channel                   : 1 (Timer21)
;
; 2. Clock                     : [ 1 m h 10 100 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 10 
;    Timer2 Pre-Divide         : 100 (MCCR Clock / 10) / 100
;
; 3. Config                    : [ 1 i p h 5 5 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 5
;    B Data                    : 5
;
; PCU (PF8)
; 1. Port Group                : 5 (PCU Port F)
;
; 2. Port                      : [ 5 8 a 1 ]
;    Pin Number                : 8 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (EC13)
;
; PCU (PC1)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 1 a 1 ]
;    Pin Number                : 1 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (T21O)

; PCU (PF8)
sendln 'cm pcu'
mpause 30
sendln 'port 5 8 a 1'
mpause 30

; PCU (PC1)
sendln 'port 2 1 a 1'
mpause 30

; Timer20
sendln 'cm timer2'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 m h 10 100'
mpause 30
sendln 'config 1 i p h 5 5'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 1'
mpause 30

; Timer13
sendln 'cm timer1'
mpause 30
sendln 'uninit 3'
mpause 30
sendln 'init 3'
mpause 30
sendln 'clk 3 e f 0'
mpause 30
sendln 'config 3 i p h 3200 3200'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 3'
