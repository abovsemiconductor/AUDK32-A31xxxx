; A. Description
;    A list of commands here configures SPI module and receives data via SPI.
;
; B. Preparation
;    Connecting ports with an external SPI device should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. SPI
;    2. PCU/GPIO
;
; D. Default Port
;    1. SPI0    : PD0 (Slave Select)
;               : PC4 (Serial Clock)
;               : PC2 (Master Out Slave In)
;               : PC3 (Master In Slave Out)
;    2. SPI1    : PE2 (Slave Select)
;               : PE3 (Serial Clock)
;               : PE5 (Master Out Slave In)
;               : PE4 (Master In Slave Out)
;
; E. Port Connection
;    1. PD0 (Slave Select)        <----> PE2 (Slave Select)
;    2. PC4 (Serial Clock)        <----> PE3 (Serial Clock)
;    3. PC2 (Master Out Slave In) <----> PE5 (Master Out Slave In)
;    4. PC3 (Master In Slave Out) <----> PE4 (Master In Slave Out)
;
; For more information, read a user's manual of the target device carefully.
;
; SPI0
; 1. Channel                   : 0 (SPI0)
;
; 2. Config                    : [ 0 i s 9 0 m h 5 -delay 1 1 1 ]
;    Operation                 : i (Interrupt)
;    Mode                      : s (Slave)
;    Data Length               : 9 (9bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 5 (PCLK / (Baudrate + 1))
;    Delay Start               : 1
;    Delay Stop                : 1
;    Delay Burst               : 1
;
; 3. Rx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; SPI1
; 1. Channel                   : 1 (SPI1)
;
; 2. Config                    : [ 1 i m 9 0 m h 5 -delay 1 1 1 ]
;    Operation                 : i (Interrupt)
;    Mode                      : m (Master)
;    Data Length               : 9 (9bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 5 (PCLK / (Baudrate + 1))
;    Delay Start               : 1
;    Delay Stop                : 1
;    Delay Burst               : 1
;
; 3. Data                      : [ 1 16 0x00 0xa5 0x01 0x5a 0x00 0xa5 0x01 0x5a 0x00 0xff 0x01 0x00 0x00 0x00 0x01 0x55 ]
;    Data Length               : 16
;    Data                      : 0x01 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Transmit Data Length      : 8
;
; PCU (PEx)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 2 a 2 ] [ 4 3 a 2 ] [ 4 5 a 2 ] [ 4 4 a 2 ]
;    Pin Number                : 2 / 3 / 5 / 4
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (SS1/SCK1/MOSI1/MISO1)
; 
; PCU (PC/D)
; 1. Port Group                : 2 / 3 (PCU Port C / D)
;
; 2. Port                      : [ 2 2 a 2 ] [ 2 3 a 2 ] [ 2 4 a 2 ] [ 3 0 a 2 ]
;    Pin Number                : 2 / 3 / 4 / 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (SPI20_MOSI20/SPI20_MISO20/SPI20_SCK20/SPI20_SS20)
; 
; PCU (PC/D)
sendln 'cm pcu'
mpause 30
sendln 'port 2 2 a 2'
mpause 30
sendln 'port 2 3 a 2'
mpause 30
sendln 'port 2 4 a 2'
mpause 30
sendln 'port 3 0 a 2'
mpause 30

; PCU (PEx)
sendln 'cm pcu'
mpause 30
sendln 'port 4 2 a 2'
mpause 30
sendln 'port 4 3 a 2'
mpause 30
sendln 'port 4 5 a 2'
mpause 30
sendln 'port 4 4 a 2'
mpause 30

; SPI0
sendln 'cm spi'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 i s 9 0 m h 5 -delay 1 1 1'
mpause 30
sendln 'rx 0 8'
mpause 100

; SPI1
sendln 'cm spi'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 i m 9 0 m h 5 -delay 1 1 1'
mpause 30
sendln 'data 1 16 0x00 0xa5 0x01 0x5a 0x00 0xa5 0x01 0x5a 0x00 0xff 0x01 0x00 0x00 0x00 0x01 0x55'
mpause 100
sendln 'tx 1 8'
