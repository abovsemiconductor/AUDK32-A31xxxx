; A. Description
;    This script automatically executes WDT, WT, CRC, CFMC, some of Timer1, some of Timer2, some of Timer3, ADC, some of PCU, and SCU Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. WDT
;    3. CRC
;    4. AES
;    5. FMC
;    6. TRNG
;    7. SCU
;    8. Timer1
;    9. Timer4E
;    10. Timer5
;    11. Timer6
;    12. ADC
;    13. TempSens
;
; C. Port Connection
;    1. ADC
;       : PE9 (Timer10 Output) ----> PA0 (AN0)
;    2. PCU
;       : PE7 (Timer11) ---> PB2 (Input)
;       : PA1 (Output) ----> PE0 (Input)
;       : PE1 (Output) ----> PB6 (Input)
;
; D.Note 
;    1. Should change a value of CONFIG_IRQ_28 to 0 /* 0 : Timer6, 1 : RTC */ at config_a31l21x.h.

timeout=3000
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0

getdir mdir
foldercreate 'Result'

fileret='01_Autotest_Result_WDT_CRC_AES_FMC_TRNG_PCU_SCU_ADC_TIMER1_TIMER4E_TIMER5_TIMER6'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tcwdt
call tccrc
call tcaes
call tctrng
call tctempsens
call tctimer1
call tctimer4e
call tctimer5
call tctimer6
call tcpcu
call tcscu
call tcadc
call tcfmc

fileclose frethnd
dispstr 'End of 1. Auto Test WDT/CRC/AES/FMC/TRNG/PCU/SCU/ADC/Timer1/Timer4E/Timer5/Timer6'
dispstr 10
dispstr 'Must process the remained PCU/SCU/Timer1/Timer4E/Timer5 TC.'
end

:tcwdt
; ===== START : TestCase WDT =====
dispstr 10 10
dispstr '===== START : TestCase WDT ====='
dispstr 10

ipstr='WDT'
foldercreate ipstr

filestr='01_wdt_intr_maskable_match'
chkstr='WDT : (0) M evt fired'
delay=5
call dotest

filestr='03_wdt_intr_reset'
chkstr='= Executable module list ='
delay=12
call dotest

filestr='04_wdt_intr_underflow'
chkstr='WDT : (0) U evt fired'
delay=5
call dotest
sendln 'stop 0'
pause 1

; ===== END : TestCase WDT =====
dispstr 10
dispstr '===== END : TestCase WDT ====='
dispstr 10
return

