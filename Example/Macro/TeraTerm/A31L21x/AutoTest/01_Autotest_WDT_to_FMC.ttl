:dotest
sprintf2 delfilename '%s\%s.log' ipstr filestr
filedelete delfilename
sprintf2 logfilename '%s\%s\%s.log' mdir ipstr filestr
logopen logfilename 0 0
sprintf2 logstr 'Test %s%s%s' filestr #13 #10
logwrite logstr
sprintf2 tcfile '..\%s\%s.ttl' ipstr filestr 
include tcfile
pause delay
logclose
call decision
return

:decision
timeout=3000
fileopen fhandle logfilename 0
if NeedReview == 1 then
    resultstr=Reviewstr
else
    filestrseek fhandle chkstr
    if result=0 then
        resultstr=Failstr
    else 
        resultstr=Passstr
    endif
endif

fileseek fhandle 0 0
do
    filereadln fhandle line
    filewriteln frethnd line
loop while result == 0
filewriteln frethnd resultstr
filewriteln frethnd 0
filewriteln frethnd 0
fileclose fhandle
NeedReview=0
resultstr=''
pause 1

return
