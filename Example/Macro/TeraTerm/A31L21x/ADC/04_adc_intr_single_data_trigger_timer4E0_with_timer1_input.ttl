; A. Description
;    A list of commands here configures ADC and generates single capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. ADC
;    2. Timer1
;    3. Timer4E
;    3. PCU/GPIO
;
; D. Default Port
;    1. ADC0    : PA0 (AN0)
;               : PA1 (AN1)
;               : PA2 (AN2)
;    2. Timer10 : PE9/PE9 (Output/Capture Input)
;
; E. Port Connection
;    1. PE9 (Timer10 Output) ----> PA0 (AN0)
;
; For more information, read a user's manual of the target device carefully.
;
; ADC0
; 1. Channel                    : 0
;
; 2. Clock                      : [ 0 p 128 ]
;    Source                     : p (PCLK)
;    Divide 		        : 128
;
; 3. Config                     : [ 0 i s 0 ]
;    Operation                  : i (Interrupt)
;    Mode                       : s (Single)
;    Sampling Time              : 0
;
; 4. Seq                        : [ 0 4 0 0x001 ]
;    Trigger Source             : 4 (Timer4E)
;    Trigger Source Number      : 0 (Timer4E0)
;    Input Channel              : 0x001 (Bit-Order)
;
; Timer10
; 1. Channel                    : 0 (Timer10)
;
; 2. Clock                      : [ 0 p 0 4095 ]
;    Source                     : p (PCLK)
;    Source Divide              : 0 (Not Available) 
;    Timer1 Pre-Divide          : 4095 (PLCK) / 4095
;
; 3. Config                     : [ 0 i p h 7814 7814 ]
;    Operation                  : i (Interrupt)
;    Mode                       : p (Period)
;    Output Port Polarity       : h (High)
;    A Data                     : 7814
;    B Data                     : 7814
;
; Timer4E0
; 1. Channel                   : 0 (Timer4E0)
;
; 2. Clock                     : [ 0 p 4095 ]
;    Source                    : p (PCLK)
;    Timer4e Pre-Divide        : 4095 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i i 3906 1953 1953 ]
;    Operation                 : i (Interrupt)
;    Mode                      : i (Interval)
;    Period                    : 3906
;    A Data                    : 1953
;    B Data                    : 1953
;
; 4. AdcTrg                    : [ 0 0x30F ]
;    Trigger Bit               : Bottom(0x200)/Period(0x100)/B-UpDown(0x00C)/A-UpDown(0x003)
;
; PCU (PE9)
; 1. Port Group                : 4 (PCU Port E)
;
; 2. Port                      : [ 4 9 a 0 ]
;    Pin Number                : 9 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (T10OUT)
;
; PCU (PA0)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 0 a 4 ]
;    Pin Number                : 0
;    Pin Mode                  : a (Alternative)
;    Alternative               : 4 (AN0)
;
; PCU (PE9)
sendln 'cm pcu'
mpause 30
sendln 'port 4 9 a 0'
mpause 30

; PCU (PA0)
sendln 'port 0 0 a 4'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 0 4095'
mpause 30
sendln 'config 0 i p h 7814 7814' 
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'
mpause 30

; Timer4E0
sendln 'cm timer4e'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 4095'
mpause 30
sendln 'config 0 i i 3906 1953 1953'
mpause 30
sendln 'adctrg 0 0x30F'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'
mpause 30

; ADC0
sendln 'cm adc'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 128'
mpause 30
sendln 'config 0 i s 0'
mpause 30
sendln 'seq 0 4 0 0x001'
mpause 30
sendln 'start 0'
pause 5
sendln 'dump 0'
pause 1
sendln 'stop 0'
mpause 30

sendln 'cm timer1'
mpause 30
sendln 'stop 0'
