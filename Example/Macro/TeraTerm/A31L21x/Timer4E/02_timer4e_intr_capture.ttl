; A. Description
;    A list of commands here configures timer3 and generates a capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer4E
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer4E0 : PC7 (TIMER4E A Output)
;                : PD0 (TIMER4E B Output)
;                : PA5 (Capture Input)
;                : PD0 (External Clock Input)
;    2. Timer12  : PF4/PF4 (Output/Capture Input)
;                : PE8 (External Clock Input)
;
; E. Port Connection
;    1. PF4 (Timer12 Output) ----> PA5 (Timer4E0 Capture Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer4E0
; 1. Channel                   : 0 (Timer4E0)
;
; 2. Clock                     : [ 0 p 4095 ]
;    Source                    : p (PCLK)
;    Timer1 Pre-Divide         : 4095 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i c b 40000 10000 20000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : c (Capture)
;    Capture Edge              : b (Both Edge)
;    Period                    : 40000
;    A Data                    : 10000
;    B Data                    : 20000
;
; Timer12
; 1. Channel                   : 2 (Timer12)
;
; 2. Clock                     : [ 2 p 0 3199 ]
;    Source                    : p (PCLK)
;    Source Divide             : 0 (Not available)
;    Timer1 Pre-Divide         : 3199 (Pre-Divide + 1)
;
; 3. Config                    : [ 2 i p h 10000 10000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 10000
;    B Data                    : 10000
;
; PCU (PF4)
; 1. Port Group                : 5 (PCU Port F)
;
; 2. Port                      : [ 5 4 a 0 ]
;    Pin Number                : 4 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (T12OUT)
;
; PCU (PA5)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 5 a 1 ]
;    Pin Number                : 5 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (T40INP)

; PCU (PF4)
sendln 'cm pcu'
mpause 30
sendln 'port 5 4 a 0'
mpause 30

; PCU(PA5)
sendln 'port 0 5 a 1'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 2'
mpause 30
sendln 'init 2'
mpause 30
sendln 'clk 2 p 0 3199'
mpause 30
sendln 'config 2 i p h 10000 10000'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 2'
mpause 30

; Timer4E0 
sendln 'cm timer4e'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 4095'
mpause 30
sendln 'config 0 i c b 40000 10000 20000'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
