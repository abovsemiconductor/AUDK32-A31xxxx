; A. Description
;    A list of commands here configures USART as UART and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. USART1  : PA13 (Transmit)
;               : PA12 (Receive)
;
; For more information, read a user's manual of the target device carefully.
;
; USART1
; 1. Channel                   : 1 (USART1)
;
; 2. Config                    : [ 1 i u 8 n 1 n 38400 ]
;    Operation                 : i (Interrupt)
;    USART Mode                : u (UART)
;    Data Bit                  : 8 (8bit)
;    Parity                    : n (None)
;    Stop Bit                  : 1 (1bit)
;    Speed Mode                : n (Normal)
;    Baudrate                  : 38400 bps
;
; 3. Rx                        : [ 1 8 ]
;    Receive Data Length       : 8
;
; PCU (PAx)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 12 a 2 -pupd p ] [ 0 13 a 2 -pupd p ]
;    Pin Number                : 12 / 13
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (RX/TX)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PAx)
sendln 'cm pcu'
mpause 30
sendln 'port 0 12 a 2 -pupd p'
mpause 30
sendln 'port 0 13 a 2 -pupd p'
mpause 30

; USART1
sendln 'cm usart'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 i u 8 n 1 n 38400'
mpause 30
sendln 'rx 1 8'
