; A. Description
;    A list of commands here configures UART and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. UART
;    2. USART
;    2. PCU/GPIO
;
; D. Default Port
;    1. UART0   : PD3 (Transmit)
;               : PD4 (Receive)
;    2. USART1  : PA13 (Transmit)
;               : PA12 (Receive)
;
; E. Port Connection
;    1. PD3 (Transmit) <----> PA12 (Receive)
;    2. PD4 (Receive)  <----> PA13 (Transmit)
;
; For more information, read a user's manual of the target device carefully.
;
; UART0
; 1. Channel                   : 0 (UART0)
;
; 2. CLK                       : [ 0 p ]
;    Clock Source              : p (PCLK : Peripheral Clock Source)
;
; 3. Config                    : [ 0 i 8 o 1 38400 ]
;    Operation                 : i (Interrupt)
;    Data Bit                  : 8 (8bit)
;    Parity                    : o (odd)
;    Stop Bit                  : 1 (1bit)
;    Baudrate                  : 38400 bps
;
; 4. Rx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; USART1
; 1. Channel                   : 1 (USART1)
;
; 2. Config                    : [ 1 d u 8 o 1 n 38400 ]
;    Operation                 : d (Interrupt DMA)
;    USART Mode                : u (UART)
;    Data Bit                  : 8 (8bit)
;    Parity                    : o (Odd)
;    Stop Bit                  : 1 (1bit)
;    Speed Mode                : n (Normal)
;    Baudrate                  : 38400 bps
;
; 3. Data                      : [ 1 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0 ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Receive Data Length       : 8
;
; PCU (PDx)
; 1. Port Group                : 3 (PCU Port D)
;
; 2. Port                      : [ 3 3 a 2 -pupd p ] [ 3 4 a 2 -pupd p ]
;    Pin Number                : 3 / 4 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (TX/RX)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PAx)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 12 a 2 -pupd p ] [ 0 13 a 2 -pupd p ]
;    Pin Number                : 12 / 13
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (RX/TX)
;    Pull-up/down              : p (Pull-up)

; PCU (PDx)
sendln 'cm pcu'
mpause 30
sendln 'port 3 3 a 2 -pupd p'
mpause 30
sendln 'port 3 4 a 2 -pupd p'
mpause 30

; PCU (PAx)
sendln 'port 0 12 a 2 -pupd p'
mpause 30
sendln 'port 0 13 a 2 -pupd p'
mpause 30

; UART0
sendln 'cm uart'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p'
mpause 30
sendln 'config 0 i 8 o 1 38400'
mpause 30
sendln 'rx 0 8'
mpause 100

; USART1
sendln 'cm usart'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 d u 8 o 1 n 38400'
mpause 30
sendln 'data 1 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0'
mpause 30
sendln 'tx 1 8'
