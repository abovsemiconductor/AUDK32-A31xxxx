; A. Description
;    A list of commands here configures timer1 and generates a periodic interrupt based on external clock source.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer1
;    2. Timer5
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer10 : PE9/PE9 (Output/Capture Input)
;               : PB10 (External Clock Input)
;    2. Timer50 : PB2 (Output)
;               : PD4 (Capture Input)
;               : PD2 (External Clock Input)
;
; E. Port Connection
;    1. PB2 (Timer50 Output) ----> PB10 (Timer10 External Clock Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer10
; 1. Channel                   : 0 (Timer10)
;
; 2. Clock                     : [ 0 e f 0 ]
;    Source                    : e (External Clock Input) 
;    External Clock Input Edge : f (Falling) 
;    Timer1 Pre-Divide         : 0 (No Pre-Divider available so default 0)
;
; 3. Config                    : [ 0 i p h 10 10 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Periodic)
;    Output Port Polarity      : h (High)
;    A Data                    : 10
;    B Data                    : 10
;
; Timer50
; 1. Channel                   : 0 (Timer50)
;
; 2. Clock                     : [ 0 m h 255 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Timer1 Pre-Divide         : 255 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i p h 6250 6250 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 6250
;    B Data                    : 6250
;
; PCU (PB10)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 10 a 2 ]
;    Pin Number                : 10 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (EC10)
;
; PCU (PB2)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 2 a 0 ]
;    Pin Number                : 2 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (T50OUT)

; PCU (PB10)
sendln 'cm pcu'
mpause 30
sendln 'port 1 10 a 2'
mpause 30

; PCU (PB2)
sendln 'port 1 2 a 0'
mpause 30

; Timer50
sendln 'cm timer5'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 255'
mpause 30
sendln 'config 0 i p h 6250 6250'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 e f 0'
mpause 30
sendln 'config 0 i p h 10 10'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
