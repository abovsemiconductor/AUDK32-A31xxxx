; A. Description
;    A list of commands here configures timer1 and generates a capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer1
;    2. Timer5
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer10 : PE9/PE9 (Output/Capture Input)
;               : PB9 (External Clock Input)
;    2. Timer50 : PB2 (Output)
;               : PD4 (Capture Input)
;               : PD2 (External Clock Input)
;
; E. Port Connection
;    1. PB2 (Timer50 Output) ----> PB9 (Timer10 Capture Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer10
; 1. Channel                   : 0 (Timer10)
;
; 2. Clock                     : [ 0 p 0 3199 ]
;    Source                    : p (PCLK)
;    Source Divide             : 0 (Not available)
;    Timer1 Pre-Divide         : 3199 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i c b h 20000 20000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : c (Capture)
;    Capture Egde              : b (Both)
;    Output Port Polarity      : h (High)
;    A Data                    : 20000
;    B Data                    : 20000
;
; Timer50
; 1. Channel                   : 0 (Timer50)
;
; 2. Clock                     : [ 0 m h 255 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Timer1 Pre-Divide         : 255 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i p h 65535 65535 ]
;    Operation                 : i (Interrupt)
;    Mode                      : p (Period)
;    Output Port Polarity      : h (High)
;    A Data                    : 65535
;    B Data                    : 65535
;
; PCU (PB9)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 9 a 1 ]
;    Pin Number                : 9 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (T10CAP)
;
; PCU (PB2)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 2 a 0 ]
;    Pin Number                : 2 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (T50OUT)

; PCU (PB9)
sendln 'cm pcu'
mpause 30
sendln 'port 1 9 a 2'
mpause 30

; PCU (PB2)
sendln 'port 1 2 a 0'
mpause 30

; Timer50
sendln 'cm timer5'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 255'
mpause 30
sendln 'config 0 i p h 65535 65535'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 0'
mpause 30

; Timer10
sendln 'cm timer1'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 0 3199'
mpause 30
sendln 'config 0 i c b h 20000 20000'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
