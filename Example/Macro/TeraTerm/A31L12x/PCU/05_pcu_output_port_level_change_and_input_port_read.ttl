; A. Description
;    A list of commands here configures PCU module and controls a output level of a target port.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;
; D. Default Port
;    1. PCU     : PC11 (Output)
;               : PF3 (Input)
;
; E. Port Connection
;    1. PC11 (Output) ----> PF3 (Input)
;
; For more information, read a user's manual of the target device carefully.
;
; PCU (PC11)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 11 o p h ]
;    Pin Number                : 11
;    Pin Mode                  : o (Output)
;    Pin Output Mode           : p (Push-Pull)
;    Pin Level                 : h (High)
;
; 3. Output                    : [ 2 11 l / h ]
;    Pin Number                : 11
;    Pin Level                 : l (Low) / h (High)
;
; PCU (PF3)
; 1. Port Group                : 5 (PCU Port F)
;
; 2. Port                      : [ 5 3 i i ]
;    Pin Number                : 3
;    Pin Mode                  : i (input)
;    Pin Output Mode           : i (input)
;
; 3. Input                     : [ 3 0 ]
;    Pin Number                : 0
;
; PCU (PC11)
sendln 'cm pcu'
mpause 30
sendln 'port 2 11 o p h'
mpause 30

; PCU (PF3)
sendln 'port 5 3 i i'
mpause 30

i = 30
do while i > 0
    i = i - 1
    if i%2 = 0 then
        sendln 'output 2 11 l'
    else
        sendln 'output 2 11 h'
    endif
    mpause 30 
    sendln 'input 5 3'
    pause 1
loop
