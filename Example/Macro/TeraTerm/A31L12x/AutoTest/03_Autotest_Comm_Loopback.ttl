; A. Description
;    This script automatically executes SPI, LPUART and UART TX/RX Tera Term example scripts.
;
; B. Prerequisite Example (abov_example_config.h)
;    1. PCU/GPIO
;    2. SPI
;    3. LPUART
;    4. UART
;
; C. Port Connection
;    1. SPI
;     : PB5 (Slave Select)        <----> PC7 (Slave Select)
;     : PB6 (Serial Clock)        <----> PD0 (Serial Clock)
;     : PB8 (Master Out Slave In) <----> PD2 (Master Out Slave In)
;     : PB7 (Master In Slave Out) <----> PD1 (Master In Slave Out)
;    2. LPUART/UART
;     : PA8 (Transmit) <----> PC2 (Receive)
;     : PA9 (Receive)  <----> PC1 (Transmit)

timeout=600
Passstr='===== Test Result : Pass ====='#13#10
Failstr='===== Test Result : Fail ====='#13#10
Reviewstr='===== Test Result : Need Review ===='#13#10
NeedReview=0
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
Resultstr=''
Resultstrcmp=0
chkstr=''

getdir mdir
foldercreate 'Result'

fileret='03_Autotest_Result_Comm_Loopback_SPI_LPUART_UART'
sprintf2 retfilename '%s\Result\%s.txt' mdir fileret
sprintf2 delfilename 'Result\%s.txt' fileret
filedelete delfilename
fileopen frethnd retfilename 0

call tclpuart
mpause 30
sendln 'cm scu'
mpause 30
sendln 'reset'
mpause 200
call tcuart
mpause 30
sendln 'cm scu'
mpause 30
sendln 'reset'
mpause 200
call tcspi

fileclose frethnd
dispstr 'End of 3. Auto Test Comm Loopback SPI/LPUART/UART'
end

:tcspi
;===== START : TestCase SPI Loopback =====
dispstr 10 10
dispstr '===== START : TestCase SPI Loopback ====='
dispstr 10 

ipstr='SPI'
foldercreate ipstr

filestr='03_spi_master_slave_intr_rx_tx_8bit'
iprxstr='SPI : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0xff 0x10 0x1 0x55 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='04_spi_master_slave_dma_rx_tx_8bit'
iprxstr='SPI : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0xff 0x10 0x1 0x55 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

;===== END : TestCase SPI Loopback =====
dispstr 10
dispstr '===== END : TestCase SPI Loopback ====='
dispstr 10 
return

:tclpuart
;===== START : TestCase LPUART Loopback =====
dispstr 10 10
dispstr '===== START : TestCase LPUART Loopback ====='
dispstr 10 

ipstr='LPUART'
foldercreate ipstr

filestr='01_lpuart_intr_rx'
iprxstr='LPUART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='02_lpuart_intr_tx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='03_lpuart_dma_rx'
iprxstr='LPUART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='04_lpuart_dma_tx'
iprxstr='LPUART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

;===== END : TestCase LPUART Loopback =====
dispstr 10
dispstr '===== END : TestCase LPUART Loopback ====='
dispstr 10 
return

:tcuart
;===== START : TestCase UART Loopback =====
dispstr 10 10
dispstr '===== START : TestCase UART Loopback ====='
dispstr 10 

ipstr='UART'
foldercreate ipstr

filestr='01_uart_intr_rx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='02_uart_intr_tx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='03_uart_dma_rx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

filestr='04_uart_dma_tx'
iprxstr='UART : rx Data'
Datastr='0xa5 0x5a 0xa5 0x5a 0x5 0x7 0x9 0xa0 0x0 0x0 0x0 0x0 0x0 0x0 0x0 0x0'
MaxDatacnt=16
Datacnt=1
index=1
delay=1
call dotest

;===== END : TestCase UART Loopback =====
dispstr 10
dispstr '===== END : TestCase UART Loopback ====='
dispstr 10 
return

:dotest
sprintf2 filename '%s\%s\%s.log' mdir ipstr filestr
sprintf2 delfilename '%s\%s.log' ipstr filestr
filedelete delfilename
sprintf2 logstr 'Test %s' filestr
sprintf2 testfile '..\%s\%s.ttl' ipstr filestr
logopen filename 0 0
logwrite logstr
include testfile
pause delay
logclose
call decision
return

:decision
timeout=600
fileopen fhandle filename 0
if Resultstrcmp == 1 then
    call cmpstr
else
    call cmpdata
endif
fileseek fhandle 0 0
do
    filereadln fhandle line
    filewriteln frethnd line
loop while result == 0
filewriteln frethnd resultstr
filewriteln frethnd 0
filewriteln frethnd 0
fileclose fhandle
NeedReview=0
Resultstrcmp=0
resultstr=''
pause 1
return

:cmpstr
if NeedReview == 1 then
    resultstr=Reviewstr
else
    filestrseek fhandle chkstr
    if result=0 then
        resultstr=Failstr
    else 
        resultstr=Passstr
    endif
endif
return

:cmpdata
fileseek fhandle 0 0
sprintf2 parsestr '%s=([a-zA-Z0-9]+)' iprxstr
while 1
    filereadln fhandle line
    if result = 1 then
        break
    endif
    strmatch line parsestr
    if result > 0 then
        dstr = groupmatchstr1
        strinsert Resultstr index dstr
        strlen dstr
        index = index + result
        if Datacnt > MaxDataCnt - 1 then
            break
        endif
        strinsert Resultstr index ' '
        index = index + 1
        Datacnt = Datacnt + 1
    endif
endwhile
;dispstr "Result : "
;dispstr Resultstr
;dispstr 10
;dispstr "Cmp : "
;dispstr Datastr
;dispstr 10
strcompare Resultstr Datastr
if result == 0 then
    resultstr=Passstr
else
    resultstr=Failstr
endif
return
