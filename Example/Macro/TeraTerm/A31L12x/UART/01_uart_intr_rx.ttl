; A. Description
;    A list of commands here configures UART and receives data.
;
; B. Preparation
;    Connecting ports with a suitable instrument should be correct
;
; C. Prerequisite Example (abov_example_config.h)
;    1. UART
;    2. LPUART
;    3. PCU/GPIO
;
; D. Default Port
;    1. UART0   : PC1 (Transmit)
;               : PC2 (Receive)
;    2. LPUART0 : PA8 (Transmit)
;               : PA9 (Receive)
;
; E. Port Connection
;    1. PC1 (Transmit) <----> PA9 (Receive)
;    2. PC2 (Receive)  <----> PA8 (Transmit)
;
; For more information, read a user's manual of the target device carefully.
;
; UART0
; 1. Channel                   : 0 (UART0)
;
; 2. CLK                       : [ 0 p ]
;    Clock Source              : p (PCLK : Peripheral Clock Source)
;
; 3. Config                    : [ 0 i 8 o 1 38400 ]
;    Operation                 : i (Interrupt)
;    Data Bit                  : 8 (8bit)
;    Parity                    : o (odd)
;    Stop Bit                  : 1 (1bit)
;    Baudrate                  : 38400 bps
;
; 4. Rx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; LPUART0
; 1. Channel                   : 0 (LPUART0)
;
; 2. CLK                       : [ 0 m h 0 ]
;    Source                    : m (MCCR : Misc Clock)
;    MCCR Source               : h (HSI : High Speed Internal Clock - 32MHz)
;    Source Divide             : 0 (Not available)
;
; 3. Config                    : [ 0 i 8 o 1 38400 ]
;    Operation                 : i (Interrupt)
;    Data Bit                  : 8 (8bit)
;    Parity                    : o (odd)
;    Stop Bit                  : 1 (1bit)
;    Baudrate                  : 38400 bps
;
; 4. Data                      : [ 0 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0 ]
;    Data Length               : 8
;    Data                      : 0xa5 ... (Hexa and space (delimitor))
;
; 5. Tx                        : [ 0 8 ]
;    Transmit Data Length      : 8
;
; PCU (PCx)
; 1. Port Group                : 2 (PCU Port C)
;
; 2. Port                      : [ 2 1 a 2 -pupd p ] [ 2 2 a 2 -pupd p ]
;    Pin Number                : 1 / 2 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (TX/RX)
;    Pull-up/down              : p (Pull-up)
;
; PCU (PCx)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 8 a 2 -pupd p ] [ 0 9 a 2 -pupd p ]
;    Pin Number                : 8 / 9 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 2 (TX/RX)
;    Pull-up/down              : p (Pull-up)

; PCU (PCx)
sendln 'cm pcu'
mpause 30
sendln 'port 2 1 a 2 -pupd p'
mpause 30
sendln 'port 2 2 a 2 -pupd p'
mpause 30

; PCU (PCx)
sendln 'port 0 8 a 2 -pupd p'
mpause 30
sendln 'port 0 9 a 2 -pupd p'
mpause 30

; UART0
sendln 'cm uart'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p'
mpause 30
sendln 'config 0 i 8 o 1 38400'
mpause 30
sendln 'rx 0 8'
mpause 100

; LPUART1
sendln 'cm lpuart'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 m h 0'
mpause 30
sendln 'config 0 i 8 o 1 38400'
mpause 30
sendln 'data 0 8 0xa5 0x5a 0xa5 0x5a 0x05 0x07 0x09 0xa0'
mpause 30
sendln 'tx 0 8'
