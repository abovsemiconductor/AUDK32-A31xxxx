; A. Description
;    A list of commands here configures WDT and generates an underflow interrupt.
;
; B. Preparation
;    N/A
;
; C. Prerequisite Example (abov_example_config.h)
;    1. WDT
;
; For more information, read a user's manual of the target device carefully.
;
; WDT0
; 1. Channel                   : 0 (WDT 0)
;
; 2. Clock                     : [ 0 w 4 ]
;    Clock Source              : w (WDTRC 40KHz)
;    WDT Pre-Divide            : 4 (Clock Source / 4) 
;
; 3. Config                    : [ 0 i m u 10000 5000 ]
;    Operation                 : i (Interrupt)
;    Interrupt Mode            : m (Maskable)
;    Mode                      : u (Underflow)
;    Inital Data               : 10000
;    Match Data                : 5000
;
; WDT0
sendln 'cm wdt'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 w 4'
mpause 30
sendln 'config 0 i m u 10000 5000'
mpause 30
sendln 'start 0'
