; A. Description
;    A list of commands here configures SPI module and receives data via SPI.
;
; B. Preparation
;    Connecting ports with an external SPI device should be correct.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. SPI
;    2. PCU/GPIO
;
; D. Default Port
;    1. SPI0    : PB5 (Slave Select)
;               : PB6 (Serial Clock)
;               : PB8 (Master Out Slave In)
;               : PB7 (Master In Slave Out)
;    2. SPI1    : PC7 (Slave Select)
;               : PD0 (Serial Clock)
;               : PD2 (Master Out Slave In)
;               : PD1 (Master In Slave Out)
;
; E. Port Connection
;    1. PB5 (Slave Select)        <----> PC7 (Slave Select)
;    2. PB6 (Serial Clock)        <----> PD0 (Serial Clock)
;    3. PB8 (Master Out Slave In) <----> PD2 (Master Out Slave In)
;    4. PB7 (Master In Slave Out) <----> PD1 (Master In Slave Out)
;
; For more information, read a user's manual of the target device carefully.
;
; SPI0
; 1. Channel                   : 0 (SPI0)
;
; 2. Config                    : [ 0 d s 8 0 m h 51 ]
;    Operation                 : d (Interrupt DMA)
;    Mode                      : s (Slave)
;    Data Length               : 8 (8bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 51 (PCLK / 2 / (Baudrate + 1))
;
; 3. Rx                        : [ 0 8 ]
;    Receive Data Length       : 8
;
; SPI1
; 1. Channel                   : 1 (SPI1)
;
; 2. Config                    : [ 1 d m 8 0 m h 51 ]
;    Operation                 : d (Interrupt DMA)
;    Mode                      : m (Master)
;    Data Length               : 8 (8bit)
;    Polarity/Phase            : 0 (Polarity : Low, Phase : Low)
;    Bit Order                 : m (MSB)
;    Slave Select Pin Polarity : h (High)
;    Baudrate                  : 51 (PCLK / 2 / (Baudrate + 1))
;
; 3. Data                      : [ 1 8 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x09 ]
;    Data Length               : 8
;    Data                      : 0x01 ... (Hexa and space (delimitor))
;
; 4. Tx                        : [ 1 8 ]
;    Transmit Data Length      : 8
;
; PCU (PBx)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 5 a 3 ] [ 1 6 a 3 ] [ 1 7 a 3 ] [ 1 8 a 3 ]
;    Pin Number                : 5 / 6 / 7 / 8
;    Pin Mode                  : a (Alternative)
;    Alternative               : 3 (SS0/SCK0/MISO0/MOSI0)
; 
; PCU (PC/Dx)
; 1. Port Group                : 2 / 3 (PCU Port C / D)
;
; 2. Port                      : [ 2 7 a 6 ] [ 3 0 a 3 ] [ 3 1 a 3 ] [ 3 2 a 3 ]
;    Pin Number                : 7 / 0 / 1 / 2
;    Pin Mode                  : a (Alternative)
;    Alternative               : 6/3 (SS0/SCK0/MISO0/MOSI0)
; 
; PCU (PBx)
sendln 'cm pcu'
mpause 30
sendln 'port 1 5 a 3 -pupd p'
mpause 30
sendln 'port 1 6 a 3 -pupd p'
mpause 30
sendln 'port 1 7 a 3 -pupd p'
mpause 30
sendln 'port 1 8 a 3 -pupd p'
mpause 30

; PCU (PC/Dx)
sendln 'port 2 7 o p h -pupd p'
mpause 30
sendln 'port 3 0 a 3 -pupd p'
mpause 30
sendln 'port 3 1 a 3 -pupd p'
mpause 30
sendln 'port 3 2 a 3 -pupd p'
mpause 30

; SPI0
sendln 'cm spi'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'config 0 d s 8 0 m h 51'
mpause 30
sendln 'rx 0 8'
mpause 100

; SPI1
sendln 'cm spi'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'config 1 d m 8 0 m h 51'
mpause 30
sendln 'data 1 8 0xa5 0x5a 0xa5 0x5a 0xff 0x10 0x01 0x55'
mpause 100
sendln 'tx 1 8'
