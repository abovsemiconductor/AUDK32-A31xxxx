; A. Description
;    A list of commands here configures timer3 and generates a capture interrupt.
;
; B. Preparation
;    Connecting target port with a suitable instrument.
;
; C. Prerequisite Example (abov_example_config.h)
;    1. Timer4E
;    2. Timer1
;    3. PCU/GPIO
;
; D. Default Port
;    1. Timer4E0 : PC7 (TIMER4E A Output)
;                : PD0 (TIMER4E B Output)
;                : PA0 (Capture Input)
;                : PD0 (External Clock Input)
;    2. Timer4E1 : PB3/PB4/PB3 (Output A/ B /Capture Input)
;                : PB4 (External Clock Input)
;
; E. Port Connection
;    1. PB3 (Timer4E1 Output A) ----> PA0 (Timer4E0 Capture Input)
;
; For more information, read a user's manual of the target device carefully.
;
; Timer4E0
; 1. Channel                   : 0 (Timer4E0)
;
; 2. Clock                     : [ 0 p 4095 ]
;    Source                    : p (PCLK)
;    Timer1 Pre-Divide         : 4095 (Pre-Divide + 1)
;
; 3. Config                    : [ 0 i c b 40000 10000 20000 ]
;    Operation                 : i (Interrupt)
;    Mode                      : c (Capture)
;    Capture Edge              : b (Both Edge)
;    Period                    : 40000
;    A Data                    : 10000
;    B Data                    : 20000
;
; Timer4E1
; 1. Channel                   : 1 (Timer4E1)
;
; 2. Clock                     : [ 1 p 4095 ]
;    Source                    : p (PCLK)
;    Timer4e Pre-Divide        : 4095 (Pre-Divide + 1)
;
; 3. Config                    : [ 1 i i -port -pa en h 7812 3906 3906 ]
;    Operation                 : i (Interrupt)
;    Mode                      : i (Interval)
;    Port                      : -pa (Port A)
;    Port Output Enable        : en (Enable)
;    Port Output Start Level   : h (High)
;    Period                    : 7814
;    A Data                    : 3907
;    B Data                    : 3907
;
; PCU (PB3)
; 1. Port Group                : 1 (PCU Port B)
;
; 2. Port                      : [ 1 3 a 0 ]
;    Pin Number                : 3 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 0 (T4E1OUT)
;
; PCU (PA0)
; 1. Port Group                : 0 (PCU Port A)
;
; 2. Port                      : [ 0 0 a 1 ]
;    Pin Number                : 0 
;    Pin Mode                  : a (Alternative)
;    Alternative               : 1 (T40INP)

; PCU(PB3)
sendln 'cm pcu'
mpause 30
sendln 'port 1 3 a 0'
mpause 30

; PCU(PA0)
sendln 'port 0 0 a 1'
mpause 30

; Timer4E0
sendln 'cm timer4e'
mpause 30
sendln 'uninit 1'
mpause 30
sendln 'init 1'
mpause 30
sendln 'clk 1 p 4095'
mpause 30
sendln 'config 1 i i -port -pa en h 7812 3906 3906'
mpause 30
sendln 'log off'
mpause 30
sendln 'start 1'
mpause 30

; Timer4E0 
sendln 'cm timer4e'
mpause 30
sendln 'uninit 0'
mpause 30
sendln 'init 0'
mpause 30
sendln 'clk 0 p 4095'
mpause 30
sendln 'config 0 i c b 40000 10000 20000'
mpause 30
sendln 'log on'
mpause 30
sendln 'start 0'
